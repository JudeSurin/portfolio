<!-- 01 NOTEGEN -->
<div class="pitem bg-ng" id="notegen">
  <div class="pcwrap" id="pw-notegen"></div>
  <div class="dg"></div>
  <div class="pfade" style="background:linear-gradient(270deg,var(--bg) 0%,transparent 55%)"></div>
  <div class="pin flip">
    <div class="pinfo">
      <div class="pnum">01 / 11</div>
      <div class="paward ab">AWS Internship · Summer 2024</div>
      <div class="pey" style="color:#4ade80">🤖 Generative AI</div>
      <h2 class="ptitle" style="background:linear-gradient(135deg,#4ade80,#22c55e,#16a34a);-webkit-background-clip:text;-webkit-text-fill-color:transparent">NoteGen</h2>
      <p class="pdesc">AWS Solution Architect Business Call Summarization AI Co-pilot built at Amazon Web Services. Leverages Bedrock Claude 3 Sonnet and Haiku, LangChain RAG pipelines with FAISS, and full AWS stack with guardrails preventing competitor mentions.</p>
