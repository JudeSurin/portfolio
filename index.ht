<!-- 02 SPACELINK -->
<div class="pitem bg-sl" id="spacelink">
  <div class="pcwrap" id="pw-spacelink"></div>
  <div class="dg"></div>
  <div class="pfade" style="background:linear-gradient(90deg,var(--bg) 0%,transparent 55%)"></div>
