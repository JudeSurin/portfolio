      <div class="pccan" style="height:160px" id="mc-notegen"></div>
      <div class="pcrow"><span>Model</span><span class="pcv" style="color:#4ade80">CLAUDE 3 SONNET</span></div>
      <div class="pcrow"><span>RAG Knowledge Base</span><span class="pcv" style="color:#30d158">● INDEXED</span></div>
