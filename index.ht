/* Modal & email - global */
var TO = 'JudeSurin1@gmail.com';

function openModal() {
  var m = document.getElementById('contactModal');
  m.style.display = 'flex';
  document.body.style.overflow = 'hidden';
  // Reset copy button
  document.getElementById('copyBtn').textContent = 'Copy';
}
function closeModal() {
  var m = document.getElementById('contactModal');
  m.style.display = 'none';
  document.body.style.overflow = '';
}
function copyEmail() {
  var btn = document.getElementById('copyBtn');
  function done() {
    if (!btn) return;
    btn.textContent = 'Copied ✓';
    btn.style.background = '#30d158';
    setTimeout(function(){ btn.textContent = 'Copy'; btn.style.background = '#2997ff'; }, 2500);
  }
  if (navigator.clipboard && window.isSecureContext) {
    navigator.clipboard.writeText(TO).then(done).catch(function(){
      var t=document.createElement('textarea'); t.value=TO;
      t.style.cssText='position:fixed;opacity:0';
      document.body.appendChild(t); t.select();
      try{document.execCommand('copy');done();}catch(e){}
      document.body.removeChild(t);
    });
  } else {
    var t=document.createElement('textarea'); t.value=TO;
    t.style.cssText='position:fixed;opacity:0';
    document.body.appendChild(t); t.select();
    try{document.execCommand('copy');done();}catch(e){}
    document.body.removeChild(t);
  }
}

function prepEmail(el) {
  /* Called via onclick on the <a> tag — this IS the trusted user gesture.
     We update the href then return true so the browser follows it naturally.
     Browsers always open mailto: from a real user click on a real <a> element. */
  var name    = document.getElementById('mName').value.trim();
  var subject = document.getElementById('mSubject').value.trim() || "Hey Jude, Let's Connect";
  var body    = document.getElementById('mBody').value.trim();
  if (!body) body = 'Hi Jude,\n\nI came across your portfolio and would love to connect!';
  if (name) body = 'From: ' + name + '\n\n' + body;
  el.href = 'mailto:' + TO
    + '?subject=' + encodeURIComponent(subject)
    + '&body='    + encodeURIComponent(body);
  /* Close modal slightly after so user sees the transition */
  setTimeout(closeModal, 400);
  return true; /* let the browser follow the mailto: link */
}

function sendEmail() {
  /* Legacy — called from nowhere now but kept for safety */
  var el = document.getElementById('emailClientLink');
  if (el) prepEmail(el);
}

/* Set up modal events after DOM is ready */
document.addEventListener('DOMContentLoaded', function() {
  var cm = document.getElementById('contactModal');
  if (cm) {
    cm.addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });
  }
});
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeModal();
});
/* mailto interceptor removed - links now use onclick directly */


/* cat JS moved to global scope */

</script>

<!-- ═══════════════════════════════════════
     CONTACT MODAL fires when email clicked
═══════════════════════════════════════ -->
<div id="contactModal" style="display:none;position:fixed;inset:0;z-index:9000;align-items:center;justify-content:center;padding:20px;background:rgba(0,0,0,.7);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px)">
  <div style="background:var(--bg2);border:1px solid var(--brd);border-radius:24px;padding:40px;max-width:520px;width:100%;box-shadow:0 32px 80px rgba(0,0,0,.6);position:relative;animation:modalIn .35s cubic-bezier(.34,1.56,.64,1)">
    <!-- Close -->
    <button onclick="closeModal()" style="position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:50%;background:var(--bg3);border:1px solid var(--brd);color:var(--t2);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s" onmouseover="this.style.background='var(--bg4)'" onmouseout="this.style.background='var(--bg3)'">×</button>
    <!-- Icon + heading -->
    <div style="font-size:40px;margin-bottom:16px">✉️</div>
    <h2 style="font-family:var(--fd);font-size:28px;font-weight:800;letter-spacing:-.025em;color:var(--t);margin-bottom:8px">Send a Message</h2>
    <p style="font-size:14px;color:var(--t2);font-weight:300;margin-bottom:28px;line-height:1.7">Fill out the form below and it will open in your email client, ready to send. Or copy the address directly.</p>
    <!-- Copy email chip -->
    <div style="display:flex;align-items:center;gap:10px;background:var(--bg3);border:1px solid var(--brd);border-radius:12px;padding:12px 16px;margin-bottom:24px">
      <span style="font-family:var(--fm);font-size:13px;color:var(--acc);flex:1">JudeSurin1@gmail.com</span>
      <button id="copyBtn" onclick="copyEmail()" style="padding:6px 14px;border-radius:8px;background:var(--acc);color:#fff;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:all .2s;font-family:var(--fm)">Copy</button>
    </div>
    <!-- Form -->
    <div style="display:flex;flex-direction:column;gap:14px">
      <div>
        <label style="font-family:var(--fm);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--t3);display:block;margin-bottom:6px">Your Name</label>
        <input id="mName" type="text" placeholder="Your name" style="width:100%;padding:12px 16px;border-radius:12px;background:var(--bg3);border:1px solid var(--brd);color:var(--t);font-family:var(--fb);font-size:14px;outline:none;transition:border-color .2s" onfocus="this.style.borderColor='var(--acc)'" onblur="this.style.borderColor='var(--brd)'">
      </div>
      <div>
        <label style="font-family:var(--fm);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--t3);display:block;margin-bottom:6px">Subject</label>
        <input id="mSubject" type="text" placeholder="What's this about?" value="Hey Jude, Let's Connect" style="width:100%;padding:12px 16px;border-radius:12px;background:var(--bg3);border:1px solid var(--brd);color:var(--t);font-family:var(--fb);font-size:14px;outline:none;transition:border-color .2s" onfocus="this.style.borderColor='var(--acc)'" onblur="this.style.borderColor='var(--brd)'">
      </div>
      <div>
        <label style="font-family:var(--fm);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--t3);display:block;margin-bottom:6px">Message</label>
        <textarea id="mBody" rows="5" placeholder="Your message..." style="width:100%;padding:12px 16px;border-radius:12px;background:var(--bg3);border:1px solid var(--brd);color:var(--t);font-family:var(--fb);font-size:14px;outline:none;resize:vertical;transition:border-color .2s;line-height:1.6" onfocus="this.style.borderColor='var(--acc)'" onblur="this.style.borderColor='var(--brd)'">Hi Jude,

I came across your portfolio and would love to connect!</textarea>
      </div>
      <a id="emailClientLink" href="mailto:JudeSurin1@gmail.com" onclick="return prepEmail(this)" style="display:block;text-align:center;padding:14px;border-radius:12px;background:linear-gradient(135deg,var(--acc),#5e5ce6);color:#fff;font-family:var(--fm);font-size:13px;font-weight:700;letter-spacing:.06em;cursor:pointer;text-decoration:none;transition:all .25s;box-shadow:0 4px 20px var(--accg)" onmouseover="this.style.transform='scale(1.02)';this.style.opacity='.9'" onmouseout="this.style.transform='scale(1)';this.style.opacity='1'">
        Open in Email Client →
      </a>
      <p style="text-align:center;font-size:11px;color:var(--t3);font-family:var(--fm)">Opens Gmail, Outlook, Apple Mail, or your default email app</p>
    </div>
  </div>
</div>

<style>
@keyframes modalIn{from{opacity:0;transform:scale(.92) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}
</style>

</body>
</html>
