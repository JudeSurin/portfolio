<!-- 03 4SIGHT -->
<div class="pitem bg-4s" id="foursight">
  <div class="pcwrap" id="pw-foursight"></div>
  <div class="dg"></div>
  <div class="pfade" style="background:linear-gradient(270deg,var(--bg) 0%,transparent 55%)"></div>
