<script>
/* ═══════════════════════════════
   THREE.JS READINESS WRAPPER
   CDN loaded async - wait for it
═══════════════════════════════ */
function waitForTHREE(cb, n) {
  n = n || 0;
  if (typeof THREE !== 'undefined') { cb(); return; }
  if (n > 200) { console.warn('THREE.js load timeout - 3D scenes disabled'); return; }
  setTimeout(function() { waitForTHREE(cb, n + 1); }, 50);
}

/* CURSOR */
var dot=document.getElementById('cDot'),ring=document.getElementById('cRing');
var mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;dot.style.left=mx+'px';dot.style.top=my+'px';});
(function loop(){rx+=(mx-rx)*.13;ry+=(my-ry)*.13;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loop);})();
document.querySelectorAll('a,button,.tog').forEach(function(el){
  el.addEventListener('mouseenter',function(){ring.style.width='54px';ring.style.height='54px';dot.style.width='16px';dot.style.height='16px';});
  el.addEventListener('mouseleave',function(){ring.style.width='36px';ring.style.height='36px';dot.style.width='10px';dot.style.height='10px';});
});
/* THEME */
function setTheme(t){document.documentElement.dataset.theme=t;document.getElementById('togIc').textContent=t==='light'?'☀️':'🌙';localStorage.setItem('jt',t);}
document.getElementById('togBtn').addEventListener('click',function(){setTheme(document.documentElement.dataset.theme==='dark'?'light':'dark');});
var st=localStorage.getItem('jt');if(st)setTheme(st);
/* NAV */
var NAVIDS=['hero','notegen','spacelink','foursight','floodguard','hoverfly','netflix','haven','everbloom','smartwear','cloud7','capitalone','experience','about','contact'];
var ntabs=document.querySelectorAll('.ntab');
function goTo(id){
  var el=document.getElementById(id);if(!el)return;
  var offset=92;/* nav(54)+catBar(38) */
  var top=el.getBoundingClientRect().top+window.pageYOffset-offset;
  window.scrollTo({top:top,behavior:'smooth'});
  document.querySelectorAll('.cat-dropdown').forEach(function(d){d.style.opacity='0';d.style.pointerEvents='none';d.style.transform='translateY(-6px)';});
}

/* ── CATEGORY BAR — global scope so onclick works immediately ── */
function showCatDropdown(id) {
  var drops = ['intern','hack','personal'];
  drops.forEach(function(d) {
    var el = document.getElementById('drop-' + d);
    if (!el) return;
    var isOpen = el.getAttribute('data-open') === '1';
    if (d === id) {
      /* Toggle this one — always repeatable */
      var nowOpen = !isOpen;
      el.setAttribute('data-open', nowOpen ? '1' : '0');
      el.style.opacity = nowOpen ? '1' : '0';
      el.style.pointerEvents = nowOpen ? 'all' : 'none';
      el.style.transform = nowOpen ? 'translateY(0)' : 'translateY(-6px)';
    } else {
      /* Close others */
      el.setAttribute('data-open', '0');
      el.style.opacity = '0';
      el.style.pointerEvents = 'none';
      el.style.transform = 'translateY(-6px)';
    }
  });
}
/* Close on outside click */
document.addEventListener('click', function(e) {
  if (!e.target.closest('.cat-wrap')) {
    ['intern','hack','personal'].forEach(function(d) {
      var el = document.getElementById('drop-' + d);
      if (el) {
        el.setAttribute('data-open','0');
        el.style.opacity='0'; el.style.pointerEvents='none'; el.style.transform='translateY(-6px)';
      }
    });

/* Global modal stubs - accessible from HTML onclick before THREE loads */
function openModal(){
  var m=document.getElementById('contactModal');
  if(m){m.style.display='flex';document.body.style.overflow='hidden';}
}
function closeModal(){
  var m=document.getElementById('contactModal');
  if(m){m.style.display='none';document.body.style.overflow='';}
}
  }
});

var nobs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){var i=NAVIDS.indexOf(e.target.id);if(i>=0){ntabs.forEach(function(t){t.classList.remove('on');});if(ntabs[i])ntabs[i].classList.add('on');}}});},{threshold:.25});
NAVIDS.forEach(function(id){var el=document.getElementById(id);if(el)nobs.observe(el);});
document.addEventListener('keydown',function(e){if(e.key!=='ArrowDown'&&e.key!=='ArrowUp')return;var cur=-1;NAVIDS.forEach(function(id,i){var el=document.getElementById(id);if(!el)return;var r=el.getBoundingClientRect();if(r.top>=-80&&r.top<window.innerHeight/2)cur=i;});if(e.key==='ArrowDown'&&cur<NAVIDS.length-1)goTo(NAVIDS[cur+1]);if(e.key==='ArrowUp'&&cur>0)goTo(NAVIDS[cur-1]);});
/* REVEAL */
var rvObs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('on');rvObs.unobserve(e.target);}});},{threshold:.08});
document.querySelectorAll('.rv').forEach(function(el){rvObs.observe(el);});
var piObs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.querySelectorAll('.pinfo,.pglass').forEach(function(el){el.classList.add('on');});piObs.unobserve(e.target);}});},{threshold:.1});
document.querySelectorAll('.pin').forEach(function(el){piObs.observe(el);});

/* ═══════════════════════════════════════════
   WEBGL — SINGLE SHARED RENDERER
   Only 1 bg renderer + 1 mini renderer active
═══════════════════════════════════════════ */
/* ═══════════════════════════════════════════════════
   ALWAYS-ON MULTI-RENDERER — Every section has its
   own dedicated WebGLRenderer so ALL animations run
   simultaneously while scrolling. Never pauses.
═══════════════════════════════════════════════════ */
var SCENES={}, MSCENES={};

/* ═══════════════════════════════════════════════════════════════
   CONTEXT-SAFE RENDERER POOL
   Problem: 23+ simultaneous WebGL contexts = Context Lost errors
   Solution: Pool of MAX_BG=5 bg renderers + MAX_MINI=3 mini renderers
   Renderers are SHARED and reassigned to whichever scene is visible.
   Each section stores its built geometry; the renderer is borrowed
   only when the section is on screen.
   setClearColor(black) on every renderer prevents white-flash.
════════════════════════════════════════════════════════════════ */
var MAX_BG = 5, MAX_MINI = 3;
var bgPool = [],  miniPool = [];
var bgQueue = [], miniQueue = []; /* LRU order: front = oldest used */

function makeRenderer(alpha, pr) {
  var cv = document.createElement('canvas');
  var r  = new THREE.WebGLRenderer({
    canvas: cv, alpha: !!alpha, antialias: true,
    powerPreference: 'high-performance'
  });
  r.setPixelRatio(Math.min(devicePixelRatio, pr || 1.3));
  r.setClearColor(0x000000, 1); /* always black — prevents white flash */

  cv.addEventListener('webglcontextlost', function(e) {
    e.preventDefault();
    /* On context loss: mark renderer as dead, recover after 500ms */
    r._lost = true;
    setTimeout(function() { tryRecoverRenderer(r); }, 500);
  }, false);
  cv.addEventListener('webglcontextrestored', function() {
    r._lost = false;
    r.setClearColor(0x000000, 1);
  }, false);

  r._lost = false;
  return { r: r, cv: cv, owner: null };
}

function tryRecoverRenderer(r) {
  /* Try to get a fresh context by forcibly losing old one */
  try {
    var ext = r.getContext().getExtension('WEBGL_lose_context');
    if (ext) ext.restoreContext();
  } catch(e) {}
}

function fitR(rObj, wrap, cam) {
  if (!rObj || rObj.r._lost) return;
  var w = wrap.offsetWidth  || wrap.clientWidth  || window.innerWidth;
  var h = wrap.offsetHeight || wrap.clientHeight || window.innerHeight;
  if (w < 2 || h < 2) return;
  rObj.r.setSize(w, h, false);
  cam.aspect = w / h;
  cam.updateProjectionMatrix();
}

/* Get or create a bg renderer from the pool */
function acquireBgRenderer(id) {
  /* First: try to reuse the renderer already owned by this scene */
  for (var i = 0; i < bgPool.length; i++) {
    if (bgPool[i].owner === id && !bgPool[i].r._lost) return bgPool[i];
  }
  /* Second: use a free slot */
  if (bgPool.length < MAX_BG) {
    var r = makeRenderer(true, 1.3);
    bgPool.push(r);
    r.owner = id;
    return r;
  }
  /* Third: evict least-recently-used (front of queue) */
  var evictId = bgQueue.shift();
  var slot = null;
  for (var j = 0; j < bgPool.length; j++) {
    if (bgPool[j].owner === evictId) { slot = bgPool[j]; break; }
  }
  if (!slot) { slot = bgPool[0]; }
  /* Detach canvas from evicted scene's wrap */
  if (slot.cv.parentNode) slot.cv.parentNode.removeChild(slot.cv);
  if (SCENES[evictId]) SCENES[evictId].rendererSlot = null;
  slot.owner = id;
  slot.r.setClearColor(0x000000, 1);
  return slot;
}

function acquireMiniRenderer(id) {
  for (var i = 0; i < miniPool.length; i++) {
    if (miniPool[i].owner === id && !miniPool[i].r._lost) return miniPool[i];
  }
  if (miniPool.length < MAX_MINI) {
    var r = makeRenderer(true, 1.1);
    miniPool.push(r);
    r.owner = id;
    return r;
  }
  var evictId = miniQueue.shift();
  var slot = null;
  for (var j = 0; j < miniPool.length; j++) {
    if (miniPool[j].owner === evictId) { slot = miniPool[j]; break; }
  }
  if (!slot) { slot = miniPool[0]; }
  if (slot.cv.parentNode) slot.cv.parentNode.removeChild(slot.cv);
  if (MSCENES[evictId]) MSCENES[evictId].rendererSlot = null;
  slot.owner = id;
  slot.r.setClearColor(0x000000, 1);
  return slot;
}

function regBg(id, buildFn, animFn) {
  var s = new THREE.Scene(); s.add(new THREE.AmbientLight(0xffffff, 0.2));
  var cam = new THREE.PerspectiveCamera(60, 1, 0.1, 600); cam.position.z = 7;
  SCENES[id] = { scene:s, cam:cam, buildFn:buildFn, animFn:animFn,
                 started:false, built:false, rendererSlot:null, animHandle:null };
}
function regMini(id, buildFn, animFn) {
  var s = new THREE.Scene(); s.add(new THREE.AmbientLight(0xffffff, 0.3));
  var cam = new THREE.PerspectiveCamera(55, 1, 0.1, 200); cam.position.z = 4;
  MSCENES[id] = { scene:s, cam:cam, buildFn:buildFn, animFn:animFn,
                  started:false, built:false, rendererSlot:null };
}

function startBg(id) {
  var info = SCENES[id]; if (!info) return;
  if (!info.started) { info.started = true; }

  var wrap = document.getElementById('pw-' + id); if (!wrap) return;

  /* Update LRU queue */
  bgQueue = bgQueue.filter(function(x){ return x !== id; });
  bgQueue.push(id);

  var slot = acquireBgRenderer(id);
  info.rendererSlot = slot;

  /* Attach canvas to this wrap */
  if (slot.cv.parentNode !== wrap) {
    wrap.innerHTML = '';
    wrap.appendChild(slot.cv);
    slot.cv.style.cssText = 'width:100%;height:100%;display:block;position:absolute;top:0;left:0;';
  }

  /* Build geometry once */
  if (!info.built) {
    info.buildFn(info.scene, info.cam, slot.r);
    info.built = true;
  }

  /* Ensure black background */
  slot.r.setClearColor(0x000000, 1);

  var doFit = function() { fitR(slot, wrap, info.cam); };
  setTimeout(doFit, 40); setTimeout(doFit, 250);
  window.addEventListener('resize', function() { setTimeout(doFit, 40); });

  /* Start loop if not already running */
  if (info.animHandle) return;
  var t0 = performance.now();
  (function loop(now) {
    info.animHandle = requestAnimationFrame(loop);
    var slot2 = info.rendererSlot;
    if (!slot2 || slot2.r._lost || slot2.owner !== id) {
      /* Renderer was evicted or lost — pause rendering but keep animating state */
      info.animFn(now - t0, info.scene, info.cam, null);
      return;
    }
    info.animFn(now - t0, info.scene, info.cam, slot2.r);
    slot2.r.render(info.scene, info.cam);
  })(t0);
}

function startMini(id) {
  var info = MSCENES[id]; if (!info || info.started) return;
  info.started = true;

  var wrap = document.getElementById('mc-' + id); if (!wrap) return;

  miniQueue = miniQueue.filter(function(x){ return x !== id; });
  miniQueue.push(id);

  var slot = acquireMiniRenderer(id);
  info.rendererSlot = slot;

  wrap.innerHTML = '';
  wrap.style.position = 'relative';
  wrap.appendChild(slot.cv);
  slot.cv.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;display:block;';

  if (!info.built) {
    info.buildFn(info.scene, info.cam, slot.r);
    info.built = true;
  }
  slot.r.setClearColor(0x000000, 1);

  var doFit = function() { fitR(slot, wrap, info.cam); };
  setTimeout(doFit, 40); setTimeout(doFit, 250);
  window.addEventListener('resize', function() { setTimeout(doFit, 40); });

  var t0 = performance.now();
  (function loop(now) {
    requestAnimationFrame(loop);
    var slot2 = info.rendererSlot;
    if (!slot2 || slot2.r._lost || slot2.owner !== id) {
      info.animFn(now - t0, info.scene, info.cam, null);
      return;
    }
    info.animFn(now - t0, info.scene, info.cam, slot2.r);
    slot2.r.render(info.scene, info.cam);
  })(t0);
}

/* Intersection observer: start bg scene when it nears viewport */
var bgObs = new IntersectionObserver(function(entries) {
  entries.forEach(function(e) {
    if (e.isIntersecting && e.target.id && SCENES[e.target.id]) {
      startBg(e.target.id);
    }
  });
}, { threshold: 0, rootMargin: '300px 0px 300px 0px' });
document.querySelectorAll('.pitem').forEach(function(el) {
  if (el.id) bgObs.observe(el);
});

/* Mini scenes lazy start */
var miniObs = new IntersectionObserver(function(entries) {
  entries.forEach(function(e) {
    if (e.isIntersecting) {
      var id = e.target.id.replace('mc-', '');
      if (MSCENES[id]) startMini(id);
    }
  });
}, { threshold: 0, rootMargin: '200px' });
document.querySelectorAll('[id^="mc-"]').forEach(function(el) {
  miniObs.observe(el);
});

/* Eagerly start first 4 scenes on load */
window.addEventListener('load', function() {
  setTimeout(function() {
    startBg('notegen'); startBg('spacelink');
    startBg('foursight'); startBg('netflix');
  }, 80);
});



/* BACKGROUND MUSIC - Interstellar: Cornfield Chase - Hans Zimmer */
/* Web Audio API approach - no <audio> element, no MIME/src issues */
var _wam = {ctx:null,buf:null,src:null,gain:null,on:false,decoding:false,decoded:false,startAt:0,pauseAt:0};

var _b64c = [
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  "",
  ""
];

function _b64ToAB(b64){
  var bin=atob(b64),ab=new ArrayBuffer(bin.length),v=new Uint8Array(ab);
  for(var i=0;i<bin.length;i++) v[i]=bin.charCodeAt(i);
  return ab;
}

function _initCtx(){
  if(_wam.ctx) return true;
  try{
    var AC=window.AudioContext||window.webkitAudioContext;
    if(!AC){console.warn("Web Audio not supported");return false;}
    _wam.ctx=new AC();
    _wam.gain=_wam.ctx.createGain();
    _wam.gain.gain.value=0;
    _wam.gain.connect(_wam.ctx.destination);
    return true;
  }catch(e){console.warn("AudioContext error:",e);return false;}
}

function _playBuf(){
  if(!_wam.buf||!_wam.ctx)return;
  if(_wam.src){try{_wam.src.stop();}catch(e){} _wam.src.disconnect();_wam.src=null;}
  var src=_wam.ctx.createBufferSource();
  src.buffer=_wam.buf; src.loop=true;
  src.connect(_wam.gain);
  var off=_wam.pauseAt%_wam.buf.duration;
  src.start(0,off);
  _wam.src=src; _wam.startAt=_wam.ctx.currentTime-off;
  _wam.on=true; _musBtnSet(true); _wFadeIn();
}

function _wFadeIn(){
  if(!_wam.gain||!_wam.ctx)return;
  _wam.gain.gain.cancelScheduledValues(0);
  _wam.gain.gain.setValueAtTime(0,_wam.ctx.currentTime);
  _wam.gain.gain.linearRampToValueAtTime(0.28,_wam.ctx.currentTime+3.0);
}

function _wFadeOut(cb){
  if(!_wam.gain||!_wam.ctx)return;
  _wam.gain.gain.cancelScheduledValues(0);
  _wam.gain.gain.setValueAtTime(_wam.gain.gain.value,_wam.ctx.currentTime);
  _wam.gain.gain.linearRampToValueAtTime(0,_wam.ctx.currentTime+1.2);
  setTimeout(function(){
    if(_wam.src){
      _wam.pauseAt=(_wam.ctx.currentTime-_wam.startAt)%(_wam.buf?_wam.buf.duration:1);
      try{_wam.src.stop();}catch(e){} _wam.src=null;
    }
    _wam.on=false; if(cb)cb();
  },1300);
}

function _decodeAndPlay(){
  if(!_initCtx())return;
  if(_wam.ctx.state==="suspended")_wam.ctx.resume();
  if(_wam.decoding)return;
  if(_wam.decoded&&_wam.buf){_playBuf();return;}
  _wam.decoding=true;
  try{
    _wam.ctx.decodeAudioData(_b64ToAB(_b64c.join("")),
      function(ab){_wam.buf=ab;_wam.decoded=true;_wam.decoding=false;_playBuf();},
      function(e){console.error("decode failed:",e);_wam.decoding=false;}
    );
  }catch(e){console.error("decode error:",e);_wam.decoding=false;}
}

function _musBtnSet(playing){
  var b=document.getElementById("musicBtn"); if(!b)return;
  b.innerHTML=playing?"&#128266;":"&#128264;";
  b.title=playing?"Pause music":"Play music";
  b.style.borderColor=playing?"rgba(41,151,255,.7)":"rgba(255,255,255,.18)";
  b.style.background=playing?"rgba(41,151,255,.3)":"rgba(10,10,20,.9)";
  b.style.boxShadow=playing?"0 0 24px rgba(41,151,255,.5)":"0 4px 24px rgba(0,0,0,.5)";
}

function toggleMusic(){
  if(_wam.on){_wFadeOut(function(){_musBtnSet(false);});}
  else{_decodeAndPlay();}
}

function _tryAutoPlay(){
  if(_wam.on||_wam.decoding)return;
  _decodeAndPlay();
}
["click","keydown","touchstart","scroll"].forEach(function(e){
  document.addEventListener(e,_tryAutoPlay,{once:true,passive:true});
});
waitForTHREE(function() {

/* ═══════════════════════════
   HERO — dedicated renderer
═══════════════════════════ */
(function(){
  var cv=document.getElementById('hCanvas');
  var hr=new THREE.WebGLRenderer({canvas:cv,alpha:false,antialias:true,powerPreference:'default'});
  hr.setPixelRatio(Math.min(devicePixelRatio,1.2));
  hr.setClearColor(0x000000,1);
  var sc=new THREE.Scene();
  var cam=new THREE.PerspectiveCamera(55,1,.1,500); cam.position.z=6;
  function fit(){var w=cv.clientWidth||window.innerWidth,h=cv.clientHeight||window.innerHeight;hr.setSize(w,h,false);cam.aspect=w/h;cam.updateProjectionMatrix();}
  window.addEventListener('resize',fit);fit();
  var N=2500,pos=new Float32Array(N*3),col=new Float32Array(N*3);
  for(var i=0;i<N;i++){pos[i*3]=(Math.random()-.5)*22;pos[i*3+1]=(Math.random()-.5)*22;pos[i*3+2]=(Math.random()-.5)*22;var t=Math.random();col[i*3]=t<.5?0:1;col[i*3+1]=t<.5?1:.24;col[i*3+2]=t<.5?.88:.67;}
  var pg=new THREE.BufferGeometry();pg.setAttribute('position',new THREE.BufferAttribute(pos,3));pg.setAttribute('color',new THREE.BufferAttribute(col,3));
  sc.add(new THREE.Points(pg,new THREE.PointsMaterial({size:.04,vertexColors:true,transparent:true,opacity:.55})));
  var knot=new THREE.Mesh(new THREE.TorusKnotGeometry(1.1,.28,110,16),new THREE.MeshPhongMaterial({color:0x2997ff,wireframe:true,transparent:true,opacity:.14}));sc.add(knot);
  sc.add(new THREE.AmbientLight(0x2997ff,.4));var pl=new THREE.PointLight(0xe879f9,2,12);pl.position.set(3,3,3);sc.add(pl);
  var hmx=0,hmy=0;document.addEventListener('mousemove',function(e){hmx=(e.clientX/window.innerWidth-.5)*2;hmy=(e.clientY/window.innerHeight-.5)*2;});
  var t0=performance.now();
  (function loop(now){requestAnimationFrame(loop);var t=now-t0;knot.rotation.x=t*.00026;knot.rotation.y=t*.00042;cam.position.x+=(hmx*.4-cam.position.x)*.04;cam.position.y+=(-hmy*.4-cam.position.y)*.04;cam.lookAt(0,0,0);hr.render(sc,cam);})(t0);
})();

/* ═══════════════════════════════════════════
   BACKGROUND SCENES — rich themed 3D objects
═══════════════════════════════════════════ */

/* NOTEGEN — AI document brain with floating papers */

/* ── Shared star field helper ── */
function addStars(sc,count,spread,opacity){
  count=count||1500; spread=spread||28; opacity=opacity||0.65;
  var sg=new THREE.BufferGeometry();
  var sp=new Float32Array(count*3);var sc2=new Float32Array(count*3);
  for(var i=0;i<count;i++){
    sp[i*3]=(Math.random()-.5)*spread;
    sp[i*3+1]=(Math.random()-.5)*spread;
    sp[i*3+2]=(Math.random()-.5)*spread;
    var t=Math.random();
    if(t<.5){sc2[i*3]=1;sc2[i*3+1]=1;sc2[i*3+2]=1;}          // white
    else if(t<.7){sc2[i*3]=0;sc2[i*3+1]=.88;sc2[i*3+2]=1;}   // cyan
    else if(t<.85){sc2[i*3]=1;sc2[i*3+1]=.17;sc2[i*3+2]=.47;} // pink
    else{sc2[i*3]=.16;sc2[i*3+1]=.6;sc2[i*3+2]=1;}            // blue
  }
  sg.setAttribute('position',new THREE.BufferAttribute(sp,3));
  sg.setAttribute('color',new THREE.BufferAttribute(sc2,3));
  var pts=new THREE.Points(sg,new THREE.PointsMaterial({size:.055,vertexColors:true,transparent:true,opacity:opacity}));
  sc.add(pts);return pts;
}

regBg('notegen',function(sc,cam,r){

  addStars(sc);
  cam.position.z=8;
  sc.add(new THREE.PointLight(0x4ade80,3,22));
  sc.add(new THREE.PointLight(0x22c55e,1.5,16));
  // AI brain core — pulsing sphere with wireframe
  var core=new THREE.Mesh(new THREE.SphereGeometry(.9,24,24),new THREE.MeshPhongMaterial({color:0x4ade80,emissive:0x4ade80,emissiveIntensity:.35,transparent:true,opacity:.75}));
  var coreW=new THREE.Mesh(new THREE.SphereGeometry(.92,14,14),new THREE.MeshPhongMaterial({color:0x22c55e,wireframe:true,transparent:true,opacity:.35}));
  sc.add(core);sc.add(coreW);
  // Floating document rectangles orbiting
  var docs=[];
  for(var i=0;i<8;i++){
    var d=new THREE.Group();
    var page=new THREE.Mesh(new THREE.BoxGeometry(.32,.42,.03),new THREE.MeshPhongMaterial({color:0x4ade80,emissive:0x166534,emissiveIntensity:.2,transparent:true,opacity:.85}));
    var line1=new THREE.Mesh(new THREE.BoxGeometry(.22,.025,.035),new THREE.MeshPhongMaterial({color:0x86efac,emissive:0x86efac,emissiveIntensity:.4}));
    var line2=new THREE.Mesh(new THREE.BoxGeometry(.18,.025,.035),new THREE.MeshPhongMaterial({color:0x86efac,emissive:0x86efac,emissiveIntensity:.4}));
    var line3=new THREE.Mesh(new THREE.BoxGeometry(.14,.025,.035),new THREE.MeshPhongMaterial({color:0x86efac,emissive:0x86efac,emissiveIntensity:.4}));
    line1.position.set(0,.1,.02);line2.position.set(-.02,.06,.02);line3.position.set(-.04,.02,.02);
    d.add(page);d.add(line1);d.add(line2);d.add(line3);
    var ang=(i/8)*Math.PI*2;
    d.position.set(Math.cos(ang)*2.8,Math.sin(ang)*2,0);
    docs.push({grp:d,a:ang,spd:.007+Math.random()*.004,yr:Math.random()*Math.PI*2});sc.add(d);
  }
  // Connection lines from docs to core
  var lns=[];
  docs.forEach(function(doc){
    var pts=[new THREE.Vector3(0,0,0),doc.grp.position.clone()];
    var l=new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts),new THREE.LineBasicMaterial({color:0x4ade80,transparent:true,opacity:.15}));
    sc.add(l);lns.push({l:l,doc:doc});
  });
  // Stars
  var sg=new THREE.BufferGeometry();var sp=new Float32Array(800*3);for(var i=0;i<800;i++){sp[i*3]=(Math.random()-.5)*28;sp[i*3+1]=(Math.random()-.5)*28;sp[i*3+2]=(Math.random()-.5)*28;}sg.setAttribute('position',new THREE.BufferAttribute(sp,3));sc.add(new THREE.Points(sg,new THREE.PointsMaterial({color:0x4ade80,size:.04,transparent:true,opacity:.2})));
  sc._core=core;sc._coreW=coreW;sc._docs=docs;sc._lns=lns;
},function(t,sc){
  if(!sc._core)return;
  sc._core.rotation.y=t*.0004;sc._coreW.rotation.y=-t*.0003;sc._coreW.rotation.x=t*.0002;
  sc._core.material.emissiveIntensity=.3+.25*Math.sin(t*.0018);
  sc._docs.forEach(function(doc){doc.a+=doc.spd;doc.yr+=.012;doc.grp.position.set(Math.cos(doc.a)*2.8,Math.sin(doc.a)*2,Math.sin(doc.a*.7)*.5);doc.grp.rotation.y=doc.yr;doc.grp.rotation.x=Math.sin(doc.a)*.2;});
  sc._lns.forEach(function(item){var pa=item.l.geometry.attributes.position.array;pa[3]=item.doc.grp.position.x;pa[4]=item.doc.grp.position.y;pa[5]=item.doc.grp.position.z;item.l.geometry.attributes.position.needsUpdate=true;});
});

/* SPACELINK — 3D Earth with realistic atmosphere + orbiting satellites */
regBg('spacelink',function(sc,cam,r){

  addStars(sc);
  cam.position.z=9;
  sc.add(new THREE.PointLight(0xffffff,2.5,30));sc.add(new THREE.PointLight(0x60a5fa,1.5,20));
  // Earth — layered spheres for depth
  var earth=new THREE.Mesh(new THREE.SphereGeometry(1.6,48,48),new THREE.MeshPhongMaterial({color:0x1a4a8a,specular:0x4488ff,shininess:40}));
  // Continent-like patches (green blobs on sphere surface)
  var earthW=new THREE.Mesh(new THREE.SphereGeometry(1.62,16,16),new THREE.MeshPhongMaterial({color:0x3b82f6,wireframe:true,transparent:true,opacity:.12}));
  // Atmosphere glow
  var atmo=new THREE.Mesh(new THREE.SphereGeometry(1.78,32,32),new THREE.MeshPhongMaterial({color:0x60a5fa,transparent:true,opacity:.08,side:THREE.BackSide}));
  // Cloud layer
  var clouds=new THREE.Mesh(new THREE.SphereGeometry(1.66,24,24),new THREE.MeshPhongMaterial({color:0xffffff,transparent:true,opacity:.07,wireframe:false}));
  sc.add(earth);sc.add(earthW);sc.add(atmo);sc.add(clouds);
  // Orbit rings
  for(var i=0;i<4;i++){var pts=[];for(var j=0;j<=100;j++)pts.push(new THREE.Vector3(Math.cos(j/100*Math.PI*2)*(2.4+i*.4),0,Math.sin(j/100*Math.PI*2)*(2.4+i*.4)));var ol=new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts),new THREE.LineBasicMaterial({color:0x818cf8,transparent:true,opacity:.12+i*.02}));ol.rotation.x=.4+i*.3;ol.rotation.z=i*.5;sc.add(ol);}
  // Satellites
  var sats=[];for(var i=0;i<10;i++){var body=new THREE.Group();var sat=new THREE.Mesh(new THREE.BoxGeometry(.1,.06,.06),new THREE.MeshPhongMaterial({color:0xc0c0c0,shininess:80}));var panelL=new THREE.Mesh(new THREE.BoxGeometry(.18,.08,.01),new THREE.MeshPhongMaterial({color:0x1e3a5f,emissive:0x60a5fa,emissiveIntensity:.3}));var panelR=new THREE.Mesh(new THREE.BoxGeometry(.18,.08,.01),new THREE.MeshPhongMaterial({color:0x1e3a5f,emissive:0x60a5fa,emissiveIntensity:.3}));panelL.position.x=-.16;panelR.position.x=.16;body.add(sat);body.add(panelL);body.add(panelR);sats.push({grp:body,r:2.4+Math.random()*1.2,a:Math.random()*Math.PI*2,inc:Math.random()*Math.PI,spd:.004+Math.random()*.006});sc.add(body);}
  // ISS trail
  var trailGeo=new THREE.BufferGeometry();var trailPos=new Float32Array(20*3);trailGeo.setAttribute('position',new THREE.BufferAttribute(trailPos,3));var trail=new THREE.Line(trailGeo,new THREE.LineBasicMaterial({color:0x00ffe0,transparent:true,opacity:.5}));sc.add(trail);
  // Stars
  var sg=new THREE.BufferGeometry();var sp=new Float32Array(2000*3);for(var i=0;i<2000;i++){sp[i*3]=(Math.random()-.5)*40;sp[i*3+1]=(Math.random()-.5)*40;sp[i*3+2]=(Math.random()-.5)*40;}sg.setAttribute('position',new THREE.BufferAttribute(sp,3));sc.add(new THREE.Points(sg,new THREE.PointsMaterial({color:0xffffff,size:.028,transparent:true,opacity:.55})));
  sc._earth=earth;sc._earthW=earthW;sc._clouds=clouds;sc._sats=sats;
},function(t,sc){
  if(!sc._earth)return;
  sc._earth.rotation.y=t*.00009;sc._earthW.rotation.y=t*.00009;sc._clouds.rotation.y=t*.00012;
  sc._sats.forEach(function(s){s.a+=s.spd;var x=Math.cos(s.a)*s.r*Math.cos(s.inc),y=Math.sin(s.inc)*s.r,z=Math.sin(s.a)*s.r;s.grp.position.set(x,y,z);s.grp.rotation.y=s.a+Math.PI/2;});
});

/* 4SIGHT — Neural network brain visualization */
regBg('foursight',function(sc,cam,r){
  cam.position.z=10;
  addStars(sc,1500,30,.45);
  sc.add(new THREE.AmbientLight(0x001a00,.5));
  sc.add(new THREE.PointLight(0x4ade80,3,24));
  sc.add(new THREE.PointLight(0x22c55e,1.5,16));

  /* ── GREEN GLOW BACKGROUND PLANES ── */
  /* Deep background radial glow — feels like the network is emanating light */
  var bgGlow = new THREE.Mesh(
    new THREE.PlaneGeometry(28, 20),
    new THREE.MeshBasicMaterial({
      color: 0x0a2a0a, transparent: true, opacity: 0.85,
      side: THREE.DoubleSide
    })
  );
  bgGlow.position.z = -3;
  sc.add(bgGlow);

  /* Central green radial bloom — brightest at center, fades out */
  var bloomColors = [
    { z: -2.8, size: 18, color: 0x0d3d0d, op: 0.9 },
    { z: -2.5, size: 12, color: 0x144d14, op: 0.6 },
    { z: -2.2, size:  8, color: 0x1a6b1a, op: 0.35 },
    { z: -2.0, size:  5, color: 0x22c55e, op: 0.12 },
    { z: -1.8, size:  3, color: 0x4ade80, op: 0.07 },
  ];
  var bloomMeshes = [];
  bloomColors.forEach(function(b) {
    var m = new THREE.Mesh(
      new THREE.PlaneGeometry(b.size, b.size * 0.72),
      new THREE.MeshBasicMaterial({
        color: b.color, transparent: true, opacity: b.op,
        side: THREE.DoubleSide
      })
    );
    m.position.z = b.z;
    sc.add(m);
    bloomMeshes.push({ mesh: m, baseOp: b.op });
  });

  /* Subtle horizontal scan lines — cyberpunk grid feel */
  for (var si = 0; si < 12; si++) {
    var y = -5 + si * 0.9;
    var scanGeo = new THREE.BufferGeometry().setFromPoints([
      new THREE.Vector3(-7, y, -2.4),
      new THREE.Vector3( 7, y, -2.4)
    ]);
    var scan = new THREE.Line(scanGeo,
      new THREE.LineBasicMaterial({ color: 0x22c55e, transparent: true, opacity: 0.04 })
    );
    sc.add(scan);
  }
  /* Vertical scan lines */
  for (var vi = 0; vi < 9; vi++) {
    var x = -4 + vi * 1.0;
    var vGeo = new THREE.BufferGeometry().setFromPoints([
      new THREE.Vector3(x, -5.5, -2.4),
      new THREE.Vector3(x,  5.5, -2.4)
    ]);
    sc.add(new THREE.Line(vGeo,
      new THREE.LineBasicMaterial({ color: 0x22c55e, transparent: true, opacity: 0.04 })
    ));
  }

  /* ── NEURAL NETWORK NODES ── */
  var layers=[3,5,6,5,3], layerX=[-4,-2,0,2,4], allNodes=[], conns=[];
  layers.forEach(function(cnt,li){
    var row=[];
    for(var ni=0;ni<cnt;ni++){
      var y=(ni-(cnt-1)/2)*1.5;
      var nd=new THREE.Mesh(new THREE.SphereGeometry(.13,16,16),
        new THREE.MeshPhongMaterial({
          color:0x4ade80, emissive:0x4ade80, emissiveIntensity:.75,
          transparent:true, opacity:.95
        }));
      nd.position.set(layerX[li], y, (Math.random()-.5)*.3);
      sc.add(nd);

      /* Per-node glow halo */
      var halo = new THREE.Mesh(
        new THREE.SphereGeometry(.28, 12, 12),
        new THREE.MeshBasicMaterial({
          color: 0x4ade80, transparent: true, opacity: 0.06
        })
      );
      halo.position.copy(nd.position);
      sc.add(halo);

      row.push({mesh:nd, halo:halo, x:layerX[li], y:y, z:nd.position.z, li:li, ni:ni});
    }
    allNodes.push(row);
  });

  /* ── CONNECTIONS WITH GLOW ── */
  for(var li=0;li<allNodes.length-1;li++){
    allNodes[li].forEach(function(fn2){
      allNodes[li+1].forEach(function(tn){
        var op=.06+Math.random()*.16;
        var mat=new THREE.LineBasicMaterial({color:0x4ade80,transparent:true,opacity:op});
        var pts=[new THREE.Vector3(fn2.x,fn2.y,fn2.z), new THREE.Vector3(tn.x,tn.y,tn.z)];
        sc.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts),mat));
        conns.push({from:fn2,to:tn,mat:mat,baseOp:op,phase:Math.random()});
      });
    });
  }

  /* ── PULSE DOTS ── */
  var pulses=[];
  for(var i=0;i<28;i++){
    var pm=new THREE.Mesh(new THREE.SphereGeometry(.07,8,8),
      new THREE.MeshPhongMaterial({
        color:0x86efac, emissive:0x86efac, emissiveIntensity:1.2,
        transparent:true, opacity:.95
      }));
    sc.add(pm);
    pulses.push({
      mesh:pm,
      conn:conns[Math.floor(Math.random()*conns.length)],
      t:Math.random(),
      spd:.004+Math.random()*.008
    });
  }

  sc._allNodes=allNodes; sc._conns=conns; sc._pulses=pulses;
  sc._bloomMeshes=bloomMeshes;
},function(t,sc){
  if(!sc._allNodes) return;

  /* Bloom pulse — breathing glow in background */
  sc._bloomMeshes.forEach(function(b, bi){
    b.mesh.material.opacity = b.baseOp * (0.8 + 0.22 * Math.sin(t * 0.0008 + bi * 0.5));
  });

  /* Node pulse and halo glow */
  sc._allNodes.forEach(function(row,li){
    row.forEach(function(n,ni){
      var pulse = 0.45 + 0.55 * Math.sin(t*.002 + li*1.1 + ni*.7);
      n.mesh.material.emissiveIntensity = pulse;
      n.mesh.scale.setScalar(1 + .12 * Math.sin(t*.003 + li*.9 + ni*.5));
      /* Halo breathes with node */
      n.halo.material.opacity = 0.04 + 0.08 * pulse;
      n.halo.scale.setScalar(1 + 0.3 * pulse);
    });
  });

  /* Edge flicker */
  sc._conns.forEach(function(cn){
    cn.mat.opacity = cn.baseOp + .12*Math.sin(t*.0015+cn.phase*6.28);
  });

  /* Pulse dots travel edges */
  sc._pulses.forEach(function(p){
    p.t += p.spd;
    if(p.t>1){ p.t=0; p.conn=sc._conns[Math.floor(Math.random()*sc._conns.length)]; }
    var f=p.conn.from, to=p.conn.to;
    p.mesh.position.set(
      f.x+(to.x-f.x)*p.t,
      f.y+(to.y-f.y)*p.t,
      f.z+(to.z-f.z)*p.t
    );
    var s=Math.sin(p.t*Math.PI);
    p.mesh.material.opacity=.3+.7*s;
    p.mesh.material.emissiveIntensity=.9+.5*s;
  });
});

regBg('floodguard',function(sc,cam,r){

  addStars(sc);
  cam.position.z=9;
  sc.add(new THREE.PointLight(0x22d3ee,3,24));sc.add(new THREE.PointLight(0x0ea5e9,1.5,16));
  // Three layered wave planes
  var waves=[];
  for(var w=0;w<3;w++){
    var pg=new THREE.PlaneGeometry(16,10,40,26);
    var plane=new THREE.Mesh(pg,new THREE.MeshPhongMaterial({color:new THREE.Color(w===0?0x22d3ee:w===1?0x0ea5e9:0x38bdf8),wireframe:true,transparent:true,opacity:.18-.04*w}));
    plane.rotation.x=-.28;plane.position.z=-w*.5;sc.add(plane);
    var pa=pg.attributes.position.array;var oY=new Float32Array(pa.length/3);for(var i=0;i<pa.length/3;i++)oY[i]=pa[i*3+1];
    waves.push({geo:pg,pa:pa,oY:oY,phase:w*1.2});
  }
  // Rain particles
  var rg=new THREE.BufferGeometry();var rp=new Float32Array(500*3);for(var i=0;i<500;i++){rp[i*3]=(Math.random()-.5)*18;rp[i*3+1]=(Math.random()-.5)*12;rp[i*3+2]=(Math.random()-.5)*6;}rg.setAttribute('position',new THREE.BufferAttribute(rp,3));sc.add(new THREE.Points(rg,new THREE.PointsMaterial({color:0x38bdf8,size:.06,transparent:true,opacity:.35})));
  // Sensor buoys
  for(var b=0;b<6;b++){var bm=new THREE.Mesh(new THREE.SphereGeometry(.12,8,8),new THREE.MeshPhongMaterial({color:0xfcd34d,emissive:0xfcd34d,emissiveIntensity:.8}));bm.position.set((Math.random()-.5)*8,(Math.random()-.5)*3,-1);sc.add(bm);}
  sc._waves=waves;
},function(t,sc){
  if(!sc._waves)return;
  sc._waves.forEach(function(w){for(var i=0;i<w.pa.length/3;i++)w.pa[i*3+1]=w.oY[i]+Math.sin(t*.002+w.pa[i*3]*.45+w.phase)*.45+Math.sin(t*.003+w.pa[i*3+2]*.35+w.phase)*.2;w.geo.attributes.position.needsUpdate=true;});
});

/* HOVERFLY — 3D Drone flying through environment */
regBg('hoverfly',function(sc,cam,r){

  addStars(sc);
  cam.position.z=7;
  sc.add(new THREE.PointLight(0xfbbf24,3.5,20));sc.add(new THREE.PointLight(0xf59e0b,1.5,14));
  // Drone body — detailed
  var droneGrp=new THREE.Group();
  var body=new THREE.Mesh(new THREE.BoxGeometry(.6,.14,.6),new THREE.MeshPhongMaterial({color:0x292524,shininess:60}));
  var topPlate=new THREE.Mesh(new THREE.BoxGeometry(.55,.05,.55),new THREE.MeshPhongMaterial({color:0xfbbf24}));topPlate.position.y=.1;
  var cam3=new THREE.Mesh(new THREE.SphereGeometry(.1,8,8),new THREE.MeshPhongMaterial({color:0x111,shininess:200}));cam3.position.set(0,-.05,.3);
  var camLens=new THREE.Mesh(new THREE.SphereGeometry(.065,8,8),new THREE.MeshPhongMaterial({color:0x1d4ed8,emissive:0x60a5fa,emissiveIntensity:.5,shininess:200}));camLens.position.set(0,-.05,.34);
  droneGrp.add(body);droneGrp.add(topPlate);droneGrp.add(cam3);droneGrp.add(camLens);
  // Arms
  var armM=new THREE.MeshPhongMaterial({color:0x44403c});
  [[-1,-1],[1,-1],[-1,1],[1,1]].forEach(function(d){
    var arm=new THREE.Mesh(new THREE.CylinderGeometry(.04,.04,.82,8),armM);
    arm.rotation.z=Math.PI/2;arm.rotation.y=Math.atan2(d[1],d[0]);arm.position.set(d[0]*.46,0,d[1]*.46);droneGrp.add(arm);
    // Motor hub
    var hub=new THREE.Mesh(new THREE.CylinderGeometry(.08,.08,.08,10),new THREE.MeshPhongMaterial({color:0xfbbf24}));hub.position.set(d[0]*.84,0,d[1]*.84);droneGrp.add(hub);
  });
  // Propellers
  var props=[];
  [[-0.84,0.05,-.84],[.84,0.05,-.84],[-.84,0.05,.84],[.84,0.05,.84]].forEach(function(p){
    var propGrp=new THREE.Group();
    for(var b=0;b<2;b++){var blade=new THREE.Mesh(new THREE.BoxGeometry(.38,.025,.08),new THREE.MeshPhongMaterial({color:0x1c1917,transparent:true,opacity:.85}));blade.rotation.y=b*Math.PI/2;propGrp.add(blade);}
    propGrp.position.set(p[0],p[1],p[2]);droneGrp.add(propGrp);props.push(propGrp);
  });
  // Landing legs
  [[-0.25,-.15,-.25],[.25,-.15,-.25],[-.25,-.15,.25],[.25,-.15,.25]].forEach(function(l){var leg=new THREE.Mesh(new THREE.CylinderGeometry(.02,.02,.2,6),new THREE.MeshPhongMaterial({color:0x44403c}));leg.position.set(l[0],l[1],l[2]);droneGrp.add(leg);});
  sc.add(droneGrp);
  // Prop wash glow rings
  var glowRings=[];
  [[-0.84,0.05,-.84],[.84,0.05,-.84],[-.84,0.05,.84],[.84,0.05,.84]].forEach(function(p){
    var gr=new THREE.Mesh(new THREE.TorusGeometry(.22,.04,6,24),new THREE.MeshPhongMaterial({color:0xfbbf24,emissive:0xfbbf24,emissiveIntensity:.8,transparent:true,opacity:.4}));
    gr.position.set(p[0],p[1],p[2]);gr.rotation.x=Math.PI/2;sc.add(gr);glowRings.push(gr);
  });
  // Flight path ribbon
  var fpPts=[];for(var i=0;i<60;i++){fpPts.push(new THREE.Vector3((i/59-.5)*12,Math.sin(i/59*Math.PI*2)*.8+Math.sin(i/59*Math.PI*4)*.3,(Math.cos(i/59*Math.PI*2))*.5));}sc.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(fpPts),new THREE.LineBasicMaterial({color:0xfbbf24,transparent:true,opacity:.18})));
  // Ground grid
  var gg=new THREE.GridHelper(14,14,0x78350f,0x78350f);gg.position.y=-2.5;gg.material.transparent=true;gg.material.opacity=.15;sc.add(gg);
  sc._droneGrp=droneGrp;sc._props=props;sc._glowRings=glowRings;
},function(t,sc){
  if(!sc._droneGrp)return;
  sc._props.forEach(function(p,i){p.rotation.y=t*.025*(i%2?1:-1);});
  sc._glowRings.forEach(function(g){g.material.emissiveIntensity=.6+.4*Math.sin(t*.02);});
  var xPos=Math.sin(t*.0006)*4,yPos=Math.sin(t*.0004)*1.2+.3,zPos=Math.cos(t*.0005)*1.5;
  sc._droneGrp.position.set(xPos,yPos,zPos);
  sc._droneGrp.rotation.x=Math.sin(t*.0004)*.08;sc._droneGrp.rotation.z=Math.sin(t*.0006)*.1;sc._droneGrp.rotation.y=t*.0004;
});

/* HAVEN — Flying dove with peace energy */
regBg('haven',function(sc,cam,r){
  cam.position.z=8;
  addStars(sc,1800,32,.55);
  sc.add(new THREE.PointLight(0xff8c42,3.5,20));
  sc.add(new THREE.PointLight(0xffd166,2,14));
  sc.add(new THREE.AmbientLight(0xff6b35,.3));
  var houseGrp=new THREE.Group();
  // Walls
  var walls=new THREE.Mesh(new THREE.BoxGeometry(2.2,1.5,.1),new THREE.MeshPhongMaterial({color:0x8b5e3c,emissive:0x3d2010,emissiveIntensity:.2}));
  walls.position.y=-.2;houseGrp.add(walls);
  // Roof
  var roofShape=new THREE.Shape();roofShape.moveTo(-1.3,0);roofShape.lineTo(1.3,0);roofShape.lineTo(0,1.1);roofShape.closePath();
  var roof=new THREE.Mesh(new THREE.ExtrudeGeometry(roofShape,{depth:.12,bevelEnabled:false}),new THREE.MeshPhongMaterial({color:0xc0392b,emissive:0x6b1a12,emissiveIntensity:.25}));
  roof.position.set(0,.55,-.06);houseGrp.add(roof);
  // Door
  var door=new THREE.Mesh(new THREE.BoxGeometry(.32,.52,.12),new THREE.MeshPhongMaterial({color:0x5c3317,emissive:0x2a1508,emissiveIntensity:.3}));
  door.position.set(0,-.46,.04);houseGrp.add(door);
  // Windows with warm glow
  [-0.6,0.6].forEach(function(x){
    var win=new THREE.Mesh(new THREE.BoxGeometry(.34,.3,.12),new THREE.MeshPhongMaterial({color:0xffd166,emissive:0xffa500,emissiveIntensity:.9,transparent:true,opacity:.85}));
    win.position.set(x,-.05,.04);houseGrp.add(win);
    var wl=new THREE.PointLight(0xffa500,1.5,3);wl.position.set(x,-.05,.6);houseGrp.add(wl);
  });
  // Chimney
  var chimney=new THREE.Mesh(new THREE.BoxGeometry(.22,.45,.22),new THREE.MeshPhongMaterial({color:0x8b5e3c}));
  chimney.position.set(.6,1.35,-.02);houseGrp.add(chimney);
  houseGrp.position.set(0,.1,0);sc.add(houseGrp);
  // Ground
  var ground=new THREE.Mesh(new THREE.PlaneGeometry(8,4),new THREE.MeshPhongMaterial({color:0x2d4a22,emissive:0x0d1a08,emissiveIntensity:.1}));
  ground.rotation.x=-Math.PI/2;ground.position.y=-1.0;sc.add(ground);
  // Smoke
  var smokeGeo=new THREE.BufferGeometry();var smokePos=new Float32Array(40*3);
  for(var i=0;i<40;i++){smokePos[i*3]=(Math.random()-.5)*.4+.6;smokePos[i*3+1]=1.5+Math.random()*2;smokePos[i*3+2]=-.02;}
  smokeGeo.setAttribute('position',new THREE.BufferAttribute(smokePos,3));
  var smoke=new THREE.Points(smokeGeo,new THREE.PointsMaterial({color:0xcccccc,size:.12,transparent:true,opacity:.25}));
  sc.add(smoke);
  // Fireflies
  var ffGeo=new THREE.BufferGeometry();var ffPos=new Float32Array(30*3);
  for(var i=0;i<30;i++){ffPos[i*3]=(Math.random()-.5)*6;ffPos[i*3+1]=(Math.random()-.5)*3+.5;ffPos[i*3+2]=(Math.random()-.5)*3;}
  ffGeo.setAttribute('position',new THREE.BufferAttribute(ffPos,3));
  var ff=new THREE.Points(ffGeo,new THREE.PointsMaterial({color:0xffd166,size:.08,transparent:true,opacity:.7}));
  sc.add(ff);
  // Moon
  var moon=new THREE.Mesh(new THREE.SphereGeometry(.35,16,16),new THREE.MeshPhongMaterial({color:0xfffde7,emissive:0xfff9c4,emissiveIntensity:.6}));
  moon.position.set(-3.5,2.5,-3);sc.add(moon);
  sc._houseGrp=houseGrp;sc._smoke=smoke;sc._smokePos=smokePos;sc._ff=ff;sc._ffPos=ffPos;
},function(t,sc){
  if(!sc._houseGrp)return;
  sc._houseGrp.rotation.y=Math.sin(t*.0003)*.04;
  sc._houseGrp.position.y=.1+Math.sin(t*.0005)*.04;
  var sp=sc._smokePos;
  for(var i=0;i<40;i++){sp[i*3+1]+=.004;if(sp[i*3+1]>3.8){sp[i*3+1]=1.5;sp[i*3]=(Math.random()-.5)*.4+.6;}}
  sc._smoke.geometry.attributes.position.needsUpdate=true;
  sc._smoke.material.opacity=.15+.1*Math.sin(t*.001);
  var fp=sc._ffPos;
  for(var i=0;i<30;i++){fp[i*3]+=Math.sin(t*.0008+i)*.002;fp[i*3+1]+=Math.cos(t*.0006+i*.5)*.002;}
  sc._ff.geometry.attributes.position.needsUpdate=true;
  sc._ff.material.opacity=.5+.4*Math.sin(t*.002);
});

regBg('everbloom',function(sc,cam,r){

  addStars(sc);
  cam.position.z=7;
  sc.add(new THREE.PointLight(0xfb7185,3,20));sc.add(new THREE.PointLight(0xf472b6,2,14));sc.add(new THREE.PointLight(0xfcd34d,.8,10));
  var roseGrp=new THREE.Group();
  // Build rose from layered petal rings — different radii and heights
  var petalLayers=[
    {count:5,r:.28,h:0,rz:.5,color:0xbe185d},
    {count:7,r:.5,h:.1,rz:.62,color:0xe11d48},
    {count:9,r:.72,h:.18,rz:.7,color:0xfb7185},
    {count:11,r:.92,h:.24,rz:.75,color:0xfca5a5},
    {count:13,r:1.1,h:.28,rz:.78,color:0xfecdd3},
  ];
  var allPetals=[];
  petalLayers.forEach(function(layer){
    for(var i=0;i<layer.count;i++){
      var ang=(i/layer.count)*Math.PI*2;
      var pShape=new THREE.Shape();
      pShape.moveTo(0,0);pShape.bezierCurveTo(.05,.15,.12,.28,.06,.36);pShape.bezierCurveTo(.02,.44,-.06,.44,-.06,.36);pShape.bezierCurveTo(-.12,.28,-.05,.15,0,0);
      var pGeo=new THREE.ShapeGeometry(pShape,8);
      var pMat=new THREE.MeshPhongMaterial({color:layer.color,side:THREE.DoubleSide,transparent:true,opacity:.88,shininess:30});
      var petal=new THREE.Mesh(pGeo,pMat);
      petal.position.set(Math.cos(ang)*layer.r,layer.h,Math.sin(ang)*layer.r);
      petal.rotation.y=ang+Math.PI/2;petal.rotation.z=layer.rz;
      allPetals.push({mesh:petal,openAngle:layer.rz,layer:petalLayers.indexOf(layer)});
      roseGrp.add(petal);
    }
  });
  // Rose center
  var center=new THREE.Mesh(new THREE.SphereGeometry(.18,12,12),new THREE.MeshPhongMaterial({color:0xfcd34d,emissive:0xfcd34d,emissiveIntensity:.5}));roseGrp.add(center);
  // Stem
  var stem=new THREE.Mesh(new THREE.CylinderGeometry(.04,.06,2.5,10),new THREE.MeshPhongMaterial({color:0x16a34a}));stem.position.y=-1.6;roseGrp.add(stem);
  // Leaves
  [[.3,-.4,.4],[-.3,-.7,-.4],[.2,-1.1,.3]].forEach(function(l){
    var lShape=new THREE.Shape();lShape.moveTo(0,0);lShape.bezierCurveTo(.2,.15,.3,.3,.1,.4);lShape.bezierCurveTo(-.1,.3,-.2,.15,0,0);
    var lGeo=new THREE.ShapeGeometry(lShape,6);
    var leaf=new THREE.Mesh(lGeo,new THREE.MeshPhongMaterial({color:0x16a34a,side:THREE.DoubleSide,transparent:true,opacity:.85}));
    leaf.position.set(l[0],l[1],l[2]);leaf.rotation.y=l[2]*2;roseGrp.add(leaf);
  });
  sc.add(roseGrp);
  // Floating petals drifting
  var floaters=[];for(var i=0;i<16;i++){var fp=new THREE.Mesh(new THREE.CircleGeometry(.08,6),new THREE.MeshPhongMaterial({color:0xfb7185,side:THREE.DoubleSide,transparent:true,opacity:.5}));fp.position.set((Math.random()-.5)*10,(Math.random()-.5)*8,(Math.random()-.5)*5);floaters.push({mesh:fp,vx:(Math.random()-.5)*.003,vy:(Math.random()-.5)*.003-.001,rx:Math.random()*.01,ry:Math.random()*.01});sc.add(fp);}
  sc._roseGrp=roseGrp;sc._allPetals=allPetals;sc._floaters=floaters;sc._bloomT=0;
},function(t,sc){
  if(!sc._roseGrp)return;
  sc._roseGrp.rotation.y=t*.0004;
  sc._roseGrp.position.y=Math.sin(t*.0005)*.15;
  // Bloom animation — petals open over time
  var bloom=Math.min(t/4000,1);
  sc._allPetals.forEach(function(p){
    var targetZ=p.openAngle*(1-bloom*.25)+bloom*0.1;
    p.mesh.rotation.z+=(targetZ-p.mesh.rotation.z)*.01;
    p.mesh.material.opacity=.5+bloom*.4;
  });
  sc._floaters.forEach(function(f){f.mesh.position.x+=f.vx;f.mesh.position.y+=f.vy;f.mesh.rotation.x+=f.rx;f.mesh.rotation.y+=f.ry;if(f.mesh.position.y<-5)f.mesh.position.y=4;});
});

/* SMARTWEAR — Wearable watch + heartbeat */
regBg('smartwear',function(sc,cam,r){

  addStars(sc);
  cam.position.z=7;
  sc.add(new THREE.PointLight(0xa78bfa,3,20));sc.add(new THREE.PointLight(0x8b5cf6,1.5,14));
  // Smartwatch
  var watchGrp=new THREE.Group();
  var watchBody=new THREE.Mesh(new THREE.BoxGeometry(.7,.7,.12),new THREE.MeshPhongMaterial({color:0x1e1b4b,shininess:80}));
  var screen=new THREE.Mesh(new THREE.BoxGeometry(.6,.6,.02),new THREE.MeshPhongMaterial({color:0x0f0e17,emissive:0xa78bfa,emissiveIntensity:.2,shininess:200}));screen.position.z=.07;
  // Watch bands
  var bandT=new THREE.Mesh(new THREE.BoxGeometry(.62,.35,.12),new THREE.MeshPhongMaterial({color:0x312e81}));bandT.position.y=.52;
  var bandB=new THREE.Mesh(new THREE.BoxGeometry(.62,.35,.12),new THREE.MeshPhongMaterial({color:0x312e81}));bandB.position.y=-.52;
  // Screen content — health metrics as geometry
  var hrLine=new THREE.Mesh(new THREE.BoxGeometry(.4,.025,.03),new THREE.MeshPhongMaterial({color:0xa78bfa,emissive:0xa78bfa,emissiveIntensity:.8}));hrLine.position.set(0,.15,.09);
  watchGrp.add(watchBody);watchGrp.add(screen);watchGrp.add(bandT);watchGrp.add(bandB);watchGrp.add(hrLine);
  sc.add(watchGrp);
  // Orbiting health rings
  var rings=[];
  [[1.4,.08,0,0xa78bfa],[1.7,.06,Math.PI/6,0x8b5cf6],[2.0,.055,Math.PI/3,0x6366f1]].forEach(function(rd){
    var ring=new THREE.Mesh(new THREE.TorusGeometry(rd[0],rd[1],10,64),new THREE.MeshPhongMaterial({color:rd[3],emissive:rd[3],emissiveIntensity:.35,transparent:true,opacity:.7}));ring.rotation.x=rd[2];rings.push({mesh:ring,speed:.0003+rd[1]*.002});sc.add(ring);
  });
  // EKG heartbeat line
  var N=120,lpts=[];for(var i=0;i<N;i++)lpts.push(new THREE.Vector3((i/N-.5)*9,0,0));
  var lGeo=new THREE.BufferGeometry().setFromPoints(lpts);sc.add(new THREE.Line(lGeo,new THREE.LineBasicMaterial({color:0xa78bfa})));
  var pa=lGeo.attributes.position.array;
  function hb(x,t){var ph=((x+t)%1+1)%1;if(ph<.04)return ph/.04*.95;if(ph<.09)return(1-ph/.09)*.95;if(ph<.13)return-(ph-.09)/.04*.5;if(ph<.22)return-(1-(ph-.13)/.09)*.5;return Math.sin(ph*Math.PI*5)*.055;}
  sc._watchGrp=watchGrp;sc._rings=rings;sc._lGeo=lGeo;sc._pa=pa;sc._hb=hb;
},function(t,sc){
  if(!sc._watchGrp)return;
  sc._watchGrp.rotation.y=Math.sin(t*.0004)*.35;sc._watchGrp.rotation.x=Math.sin(t*.0003)*.12;sc._watchGrp.position.y=Math.sin(t*.0005)*.2;
  sc._rings.forEach(function(ring){ring.mesh.rotation.y+=ring.speed;ring.mesh.material.emissiveIntensity=.25+.25*Math.sin(t*.002+ring.speed*1000);});
  for(var i=0;i<120;i++)sc._pa[i*3+1]=sc._hb(i/120,t*.0005);
  sc._lGeo.attributes.position.needsUpdate=true;
});

/* CLOUD 7 — 3D Volumetric cloud system */
regBg('cloud7',function(sc,cam,r){

  addStars(sc);
  cam.position.z=8;
  sc.add(new THREE.PointLight(0x38bdf8,3,22));sc.add(new THREE.PointLight(0x7dd3fc,1.5,16));
  // Build multiple cloud masses from sphere clusters
  function makeCloud(cx,cy,cz,scale,color){
    var cGrp=new THREE.Group();
    var sphereData=[[0,0,0,1],[.9,.15,0,.85],[-.8,.1,0,.8],[.4,.7,0,.75],[-.4,.65,0,.7],[.3,-.3,0,.65],[-.2,.85,.2,.6],[.7,.5,-.2,.65]];
    sphereData.forEach(function(d){
      var s=new THREE.Mesh(new THREE.SphereGeometry(d[3],12,12),new THREE.MeshPhongMaterial({color:color,transparent:true,opacity:.18,shininess:10}));
      var sw=new THREE.Mesh(new THREE.SphereGeometry(d[3]*.98,9,9),new THREE.MeshPhongMaterial({color:color,wireframe:true,transparent:true,opacity:.12}));
      s.position.set(d[0],d[1],d[2]);sw.position.set(d[0],d[1],d[2]);cGrp.add(s);cGrp.add(sw);
    });
    cGrp.position.set(cx,cy,cz);cGrp.scale.setScalar(scale);return cGrp;
  }
  var c1=makeCloud(0,.5,0,1.3,0x38bdf8);var c2=makeCloud(-3,-1,1,.9,0x7dd3fc);var c3=makeCloud(3.5,0.5,-1,1.1,0x0ea5e9);var c4=makeCloud(-1,2.5,-2,1.0,0x38bdf8);
  sc.add(c1);sc.add(c2);sc.add(c3);sc.add(c4);
  // Lightning bolt
  var lbPts=[new THREE.Vector3(0,2.5,0),new THREE.Vector3(.3,1.5,0),new THREE.Vector3(-.1,.8,0),new THREE.Vector3(.2,.1,0),new THREE.Vector3(0,-1.5,0)];
  var lbGeo=new THREE.BufferGeometry().setFromPoints(lbPts);
  var lb=new THREE.Line(lbGeo,new THREE.LineBasicMaterial({color:0xfcd34d,transparent:true,opacity:.9}));lb.position.set(.5,0,0);sc.add(lb);
  // Floating data nodes
  var nodes=[];for(var i=0;i<14;i++){var n=new THREE.Mesh(new THREE.BoxGeometry(.1,.1,.1),new THREE.MeshPhongMaterial({color:0x38bdf8,emissive:0x38bdf8,emissiveIntensity:.8}));n.position.set((Math.random()-.5)*9,(Math.random()-.5)*5,(Math.random()-.5)*3);nodes.push({mesh:n,oy:n.position.y,spd:Math.random()*.003+.001});sc.add(n);}
  // Rain streaks
  var rain=new THREE.BufferGeometry();var rp=new Float32Array(300*3);for(var i=0;i<300;i++){rp[i*3]=(Math.random()-.5)*14;rp[i*3+1]=(Math.random()-.5)*10;rp[i*3+2]=(Math.random()-.5)*5;}rain.setAttribute('position',new THREE.BufferAttribute(rp,3));sc.add(new THREE.Points(rain,new THREE.PointsMaterial({color:0x7dd3fc,size:.05,transparent:true,opacity:.25})));
  sc._c1=c1;sc._c2=c2;sc._c3=c3;sc._c4=c4;sc._lb=lb;sc._nodes=nodes;
},function(t,sc){
  if(!sc._c1)return;
  sc._c1.position.x=Math.sin(t*.0002)*1.5;sc._c1.position.y=.5+Math.sin(t*.0003)*.3;
  sc._c2.position.x=-3+Math.sin(t*.00025)*1;sc._c2.position.y=-1+Math.sin(t*.00035)*.25;
  sc._c3.position.x=3.5+Math.sin(t*.0003)*.8;
  sc._c4.position.x=-1+Math.sin(t*.0002)*.6;
  sc._lb.material.opacity=.4+.6*Math.abs(Math.sin(t*.0015));sc._lb.scale.setScalar(1+.1*Math.sin(t*.003));
  sc._nodes.forEach(function(n){n.mesh.position.y=n.oy+Math.sin(t*n.spd)*.5;n.mesh.rotation.y=t*.003;});
  scene_c7_rot=(t*.00015);sc._c1.rotation.y=scene_c7_rot;
});

/* CAPITAL ONE — Spinning credit cards + coins */
regBg('capitalone',function(sc,cam,r){

  addStars(sc);
  cam.position.z=7;
  sc.add(new THREE.PointLight(0xf87171,3,20));sc.add(new THREE.PointLight(0xfcd34d,1.5,14));
  // Multiple credit cards at different angles
  var cards=[];
  [[0,0,0,0,0,0],[-.3,.3,1,-Math.PI/8,Math.PI/6,0],[.3,-.2,-1,Math.PI/10,-Math.PI/5,0]].forEach(function(cd,idx){
    var cGrp=new THREE.Group();
    var cb=new THREE.Mesh(new THREE.BoxGeometry(3.1,1.95,.09),new THREE.MeshPhongMaterial({color:[0x1c0a0a,0x0a0a1c,0x0a1c0a][idx],shininess:120}));
    var stripe=new THREE.Mesh(new THREE.BoxGeometry(3.1,.38,.1),new THREE.MeshPhongMaterial({color:[0xef4444,0x3b82f6,0x22c55e][idx],emissive:[0xef4444,0x3b82f6,0x22c55e][idx],emissiveIntensity:.4}));stripe.position.y=.3;
    var chip=new THREE.Mesh(new THREE.BoxGeometry(.38,.28,.11),new THREE.MeshPhongMaterial({color:0xfcd34d}));chip.position.set(-.85,-.1,.06);
    // Card logo circle
    var logo=new THREE.Mesh(new THREE.TorusGeometry(.28,.06,8,24),new THREE.MeshPhongMaterial({color:0xfcd34d,emissive:0xfcd34d,emissiveIntensity:.4}));logo.position.set(.9,.3,.06);
    cGrp.add(cb);cGrp.add(stripe);cGrp.add(chip);cGrp.add(logo);
    cGrp.position.set(cd[0],cd[1],cd[2]);cGrp.rotation.set(cd[3],cd[4],cd[5]);
    cards.push({grp:cGrp,rotSpd:(.005+idx*.003)*(idx%2?1:-1)});sc.add(cGrp);
  });
  // Gold coins orbiting
  var coins=[];for(var i=0;i<12;i++){var c=new THREE.Mesh(new THREE.CylinderGeometry(.16,.16,.04,16),new THREE.MeshPhongMaterial({color:0xfcd34d,emissive:0xfcd34d,emissiveIntensity:.5,shininess:100}));var ang=(i/12)*Math.PI*2;c.position.set(Math.cos(ang)*3.2,Math.sin(ang)*2.2,.5);coins.push({mesh:c,a:ang,spd:.011+Math.random()*.005,yr:Math.random()*Math.PI*2});sc.add(c);}
  // $ sign particles
  sc._cards=cards;sc._coins=coins;
},function(t,sc){
  if(!sc._cards)return;
  sc._cards.forEach(function(cd){cd.grp.rotation.y+=cd.rotSpd*.003;cd.grp.position.y+=Math.sin(t*.0004+cd.rotSpd*100)*.002;});
  sc._coins.forEach(function(c){c.a+=c.spd;c.yr+=.008;c.mesh.position.set(Math.cos(c.a)*3.2,Math.sin(c.a)*2.2,.5);c.mesh.rotation.y=c.yr;c.mesh.material.emissiveIntensity=.4+.3*Math.sin(c.a*3);});
});

var scene_c7_rot=0;

/* ═══════════════════════════════════════════
   MINI SCENES
═══════════════════════════════════════════ */

regBg('netflix',function(sc,cam,r){
  cam.position.set(0, 0, 7);
  cam.lookAt(0, 0, 0);
  r.setClearColor(0x000000, 1);

  sc.add(new THREE.AmbientLight(0xffffff, 0.4));
  var keyLight = new THREE.PointLight(0xffffff, 2.5, 20);
  keyLight.position.set(4, 3, 5); sc.add(keyLight);
  var fillLight = new THREE.PointLight(0xff3300, 1.5, 14);
  fillLight.position.set(-3, -1, 4); sc.add(fillLight);

  /* ── STATIC COLOR STREAKS ── */
  var sCols = [
    0x3d0000,0x7a0000,0xe50914,0xff4400,0xff7700,0xffaa00,
    0xffcc44,0xffdd99,0xffbbcc,0xff77aa,0xdd2288,0x9911aa,
    0x5522cc,0x2233dd,0x0066ff,0x0099ff,0x22bbff,0x55ddff,0x88eeff,0xaaffff
  ];
  var streaks = [];
  var nSC = sCols.length, totW = 14.0, sW = totW/nSC;
  for(var i=0;i<nSC;i++){
    var sM2 = new THREE.Mesh(
      new THREE.BoxGeometry(sW*0.86, 9.5, 0.05),
      new THREE.MeshBasicMaterial({color:sCols[i], transparent:true, opacity:0.5+i/nSC*0.25})
    );
    sM2.position.set(-totW/2+i*sW+sW/2, 0, -2.5);
    streaks.push({mesh:sM2, base:0.5+i/nSC*0.25, phase:i*0.38});
    sc.add(sM2);
  }


  /* ── CLEAN 3D N — 3 separate extruded quads, no self-intersections ── */
  var nMat = new THREE.MeshPhongMaterial({
    color: 0xe50914, emissive: 0xaa0000, emissiveIntensity: 0.3,
    shininess: 110, specular: 0xff7777
  });
  var nMatSide = new THREE.MeshPhongMaterial({
    color: 0x7a0000, emissive: 0x300000, emissiveIntensity: 0.15, shininess: 30
  });
  var nMats = [nMat, nMatSide];
  var nGrp = new THREE.Group();

  function nExtQuad(x0,y0,x1,y1,x2,y2,x3,y3, depth){
    /* Extrude a quad (4 corners) to given depth.
       Points: bottom-left, top-left, top-right, bottom-right (clockwise) */
    var sh = new THREE.Shape();
    sh.moveTo(x0,y0); sh.lineTo(x1,y1); sh.lineTo(x2,y2); sh.lineTo(x3,y3);
    sh.closePath();
    return new THREE.ExtrudeGeometry(sh, {
      depth: depth, bevelEnabled: true,
      bevelThickness: 0.025, bevelSize: 0.018, bevelSegments: 2
    });
  }

  var _lx0=-1.1000, _lx1=-0.6500, _rx0=0.6500, _rx1=1.1000;
  var _ty=1.5000, _by=-1.5000, _dep=0.5;

  /* LEFT BAR — simple rectangle */
  var nLGeo = nExtQuad(_lx0,_by, _lx0,_ty, _lx1,_ty, _lx1,_by, _dep);
  var nL = new THREE.Mesh(nLGeo, nMats);
  nGrp.add(nL);

  /* RIGHT BAR — simple rectangle */
  var nRGeo = nExtQuad(_rx0,_by, _rx0,_ty, _rx1,_ty, _rx1,_by, _dep);
  var nR = new THREE.Mesh(nRGeo, nMats);
  nGrp.add(nR);

  /* DIAGONAL BAND — parallelogram from TL-inner corner to BR-inner corner
     Top edge:    (lx1, ty)  → (rx0, ty)   but clipped so it's really:
     The 4 corners of the diagonal band:
       top-left-inner  (lx1, ty)
       top-right-inner (rx0, ty)  ← but this overlaps right bar top, use midpoint
     Actually: diagonal band corners (no overlap with bars):
       TL = (lx1,  ty)        top of left bar inner edge
       BL = (lx1, -ty+_bw*0) ← just lx1,ty going diagonal
     
     Correct diagonal quad:
       top-left:     (_lx1, _ty)
       top-right:    (_rx0, _ty)   — but we want DIAGONAL, not horizontal top
       
     The actual diagonal band is a parallelogram:
       corner A: (_lx1, _ty)   — top of left bar, inner edge
       corner B: (_rx0, _by)   — bottom of right bar, inner edge  
       corner C: (_rx1, _by)   — bottom of right bar, outer edge  ← NO
       
     Actually the diagonal goes from:
       top-left-inner  (_lx1, _ty)  to  bottom-right-inner (_rx0, _by)  ← one edge
       top-left-outer  (_lx0, _ty)? No...
       
     The diagonal band width = BW (same as bars)
     Its 4 corners:
       P1: (_lx1, _ty)           ← top, left side (inner edge of left bar, top)
       P2: (_rx0, _by)           ← bottom, right side (inner edge of right bar, bottom)
       P3: (_rx0+_bw_offset, _by)  ← need to go BW in the perpendicular direction
       
     Simplest correct approach: diagonal as rotated box
     Length = sqrt((rx0-lx1)^2 + (ty-by)^2), width=BW, center at midpoint
  */
  var _cx = (_lx1 + _rx0) / 2;
  var _cy = (_ty + _by) / 2;
  var _dx = _rx0 - _lx1;
  var _dy = _by - _ty;
  var _len = Math.sqrt(_dx*_dx + _dy*_dy);
  var _ang = Math.atan2(_dy, _dx);
  var nDGeo = new THREE.BoxGeometry(0.450, _len, _dep + 0.001);
  var nD = new THREE.Mesh(nDGeo, nMat);
  nD.position.set(_cx, _cy, _dep/2);
  nD.rotation.z = _ang + Math.PI/2;
  nGrp.add(nD);

  nGrp.position.z = 0.950;


  sc.add(nGrp);

  /* Red halo behind N */
  var halo = new THREE.PointLight(0xff1100, 2.8, 6);
  halo.position.set(0, 0, 0.8); sc.add(halo);

  sc._nGrp=nGrp; sc._streaks=streaks; sc._keyLight=keyLight; sc._halo=halo;
},function(t,sc){
  if(!sc._nGrp) return;

  /* N: gentle float, very slow Y rotation */
  sc._nGrp.position.y = Math.sin(t*0.0003)*0.05;
  sc._nGrp.rotation.y = Math.sin(t*0.0002)*0.05;

  /* Streaks: barely-moving opacity breath */
  sc._streaks.forEach(function(s){
    s.mesh.material.opacity = s.base + 0.1*Math.sin(t*0.0004 + s.phase);
  });

  /* Slow key light orbit */
  sc._keyLight.position.x = 4*Math.cos(t*0.00018);
  sc._keyLight.position.y = 3+Math.sin(t*0.00014)*1.2;

  /* Halo gentle pulse */
  sc._halo.intensity = 2.2+0.8*Math.sin(t*0.0011);
});

regMini('netflix',function(sc,cam,r){
  cam.position.set(0,0,5);
  r.setClearColor(0x000000,1);
  sc.add(new THREE.AmbientLight(0xffffff,0.4));
  sc.add(new THREE.PointLight(0xffffff,2.0,10));
  sc.add(new THREE.PointLight(0xff2200,2.0,6));
  var mCols=[0x7a0000,0xe50914,0xff4400,0xffaa00,0xffcc44,0xff77aa,0xdd2288,0x5522cc,0x0066ff,0x22bbff,0x55ddff,0x88eeff];
  var ms2=8.0/mCols.length;
  for(var i=0;i<mCols.length;i++){
    var mm=new THREE.Mesh(new THREE.BoxGeometry(ms2*.86,6,.04),
      new THREE.MeshBasicMaterial({color:mCols[i],transparent:true,opacity:.55}));
    mm.position.set(-4+i*ms2+ms2/2,0,-1.2); sc.add(mm);
  }

  /* ── CLEAN 3D N — 3 separate extruded quads, no self-intersections ── */
  var mnMat = new THREE.MeshPhongMaterial({
    color: 0xe50914, emissive: 0xaa0000, emissiveIntensity: 0.3,
    shininess: 110, specular: 0xff7777
  });
  var mnMatSide = new THREE.MeshPhongMaterial({
    color: 0x7a0000, emissive: 0x300000, emissiveIntensity: 0.15, shininess: 30
  });
  var mnMats = [mnMat, mnMatSide];
  var mnGrp = new THREE.Group();

  function mnExtQuad(x0,y0,x1,y1,x2,y2,x3,y3, depth){
    /* Extrude a quad (4 corners) to given depth.
       Points: bottom-left, top-left, top-right, bottom-right (clockwise) */
    var sh = new THREE.Shape();
    sh.moveTo(x0,y0); sh.lineTo(x1,y1); sh.lineTo(x2,y2); sh.lineTo(x3,y3);
    sh.closePath();
    return new THREE.ExtrudeGeometry(sh, {
      depth: depth, bevelEnabled: true,
      bevelThickness: 0.025, bevelSize: 0.018, bevelSegments: 2
    });
  }

  var _lx0=-0.8000, _lx1=-0.4700, _rx0=0.4700, _rx1=0.8000;
  var _ty=1.1000, _by=-1.1000, _dep=0.38;

  /* LEFT BAR — simple rectangle */
  var mnLGeo = mnExtQuad(_lx0,_by, _lx0,_ty, _lx1,_ty, _lx1,_by, _dep);
  var mnL = new THREE.Mesh(mnLGeo, mnMats);
  mnGrp.add(mnL);

  /* RIGHT BAR — simple rectangle */
  var mnRGeo = mnExtQuad(_rx0,_by, _rx0,_ty, _rx1,_ty, _rx1,_by, _dep);
  var mnR = new THREE.Mesh(mnRGeo, mnMats);
  mnGrp.add(mnR);

  /* DIAGONAL BAND — parallelogram from TL-inner corner to BR-inner corner
     Top edge:    (lx1, ty)  → (rx0, ty)   but clipped so it's really:
     The 4 corners of the diagonal band:
       top-left-inner  (lx1, ty)
       top-right-inner (rx0, ty)  ← but this overlaps right bar top, use midpoint
     Actually: diagonal band corners (no overlap with bars):
       TL = (lx1,  ty)        top of left bar inner edge
       BL = (lx1, -ty+_bw*0) ← just lx1,ty going diagonal
     
     Correct diagonal quad:
       top-left:     (_lx1, _ty)
       top-right:    (_rx0, _ty)   — but we want DIAGONAL, not horizontal top
       
     The actual diagonal band is a parallelogram:
       corner A: (_lx1, _ty)   — top of left bar, inner edge
       corner B: (_rx0, _by)   — bottom of right bar, inner edge  
       corner C: (_rx1, _by)   — bottom of right bar, outer edge  ← NO
       
     Actually the diagonal goes from:
       top-left-inner  (_lx1, _ty)  to  bottom-right-inner (_rx0, _by)  ← one edge
       top-left-outer  (_lx0, _ty)? No...
       
     The diagonal band width = BW (same as bars)
     Its 4 corners:
       P1: (_lx1, _ty)           ← top, left side (inner edge of left bar, top)
       P2: (_rx0, _by)           ← bottom, right side (inner edge of right bar, bottom)
       P3: (_rx0+_bw_offset, _by)  ← need to go BW in the perpendicular direction
       
     Simplest correct approach: diagonal as rotated box
     Length = sqrt((rx0-lx1)^2 + (ty-by)^2), width=BW, center at midpoint
  */
  var _cx = (_lx1 + _rx0) / 2;
  var _cy = (_ty + _by) / 2;
  var _dx = _rx0 - _lx1;
  var _dy = _by - _ty;
  var _len = Math.sqrt(_dx*_dx + _dy*_dy);
  var _ang = Math.atan2(_dy, _dx);
  var mnDGeo = new THREE.BoxGeometry(0.330, _len, _dep + 0.001);
  var mnD = new THREE.Mesh(mnDGeo, mnMat);
  mnD.position.set(_cx, _cy, _dep/2);
  mnD.rotation.z = _ang + Math.PI/2;
  mnGrp.add(mnD);

  mnGrp.position.z = 1.010;
  sc.add(mnGrp);
  sc.add(new THREE.PointLight(0xff1100,2.5,5));
  sc._mnGrp=mnGrp;
},function(t,sc){
  if(!sc._mnGrp)return;
  sc._mnGrp.rotation.y=Math.sin(t*.00022)*.06;
  sc._mnGrp.position.y=Math.sin(t*.0003)*.05;
});

