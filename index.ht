<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="description" content="Jude Surin, Engineer, Product Engineer, Visionary. M.S. Data Science and AI, Apple Alliance Fellow, FIU.">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta property="og:title" content="Jude Surin Portfolio">
<meta property="og:description" content="9 projects. 4 hackathon wins. Gates Foundation Finalist. Apple Alliance Fellow.">
<meta property="og:type" content="website">
<meta name="theme-color" content="#07070a">
<title>Jude Surin · Engineer · Product Engineer · Visionary</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" media="all">
<script>
/* Three.js multi-CDN fallback loader */
(function() {
  var CDNS = [
    'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js',
    'https://unpkg.com/three@0.128.0/build/three.min.js',
    'https://cdn.jsdelivr.net/npm/three@0.128.0/build/three.min.js'
  ];
  var idx = 0;
  function tryNext() {
    if (idx >= CDNS.length) { console.error('Three.js: all CDNs failed'); return; }
    var s = document.createElement('script');
    s.src = CDNS[idx++];
    s.onerror = tryNext;
    document.head.appendChild(s);
  }
  tryNext();
})();
</script>
<style>
:root{--ease:cubic-bezier(.25,.46,.45,.94);--spring:cubic-bezier(.34,1.56,.64,1);--fd:"Syne","Gill Sans MT","Century Gothic","Trebuchet MS",sans-serif;--fb:"DM Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif;--fm:"JetBrains Mono","SF Mono","Fira Code","Roboto Mono","Courier New",monospace;}
[data-theme="dark"]{--bg:#07070a;--bg2:#0f0f14;--bg3:#17171e;--bg4:#202028;--brd:rgba(255,255,255,.07);--brdh:rgba(255,255,255,.16);--t:#f0f0f5;--t2:#85858f;--t3:#404048;--acc:#2997ff;--accg:rgba(41,151,255,.15);--nav:rgba(7,7,10,.9);--sh:0 28px 72px rgba(0,0,0,.6);--pill:rgba(255,255,255,.06);--pillb:rgba(255,255,255,.1);--tog:#26262e;--glass:rgba(255,255,255,.04);--glassb:rgba(255,255,255,.1);}
[data-theme="light"]{--bg:#f8f8fc;--bg2:#f0f0f5;--bg3:#e6e6ed;--bg4:#d8d8e0;--brd:rgba(0,0,0,.07);--brdh:rgba(0,0,0,.15);--t:#10101a;--t2:#58586a;--t3:#aaaab8;--acc:#0071e3;--accg:rgba(0,113,227,.1);--nav:rgba(248,248,252,.92);--sh:0 28px 72px rgba(0,0,0,.07);--pill:rgba(0,0,0,.04);--pillb:rgba(0,0,0,.08);--tog:#d0d0da;--glass:rgba(255,255,255,.75);--glassb:rgba(0,0,0,.1);}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
body{background:var(--bg);color:var(--t);font-family:var(--fb);overflow-x:hidden;transition:background .45s,color .45s;cursor:none}
a[href^="mailto:"]{cursor:pointer!important}
a{color:var(--acc);text-decoration:none} button{border:none;background:none;cursor:none;font-family:inherit}
#cDot{position:fixed;width:10px;height:10px;background:var(--acc);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:exclusion;transition:width .18s,height .18s}
#cRing{position:fixed;width:36px;height:36px;border:1.5px solid rgba(41,151,255,.45);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .28s,height .28s}
[data-theme="light"] #cRing{border-color:rgba(0,113,227,.3)}
nav{position:fixed;top:0;left:0;right:0;z-index:300;height:54px;background:var(--nav);backdrop-filter:saturate(180%) blur(24px);-webkit-backdrop-filter:saturate(180%) blur(24px);border-bottom:1px solid var(--brd);transition:background .45s,border-color .45s}
.nav-in{max-width:1140px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 28px;height:100%}
.nav-brand{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-mark{width:30px;height:30px;border-radius:8px;background:var(--acc);display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px var(--accg)}
.nav-mark svg{width:16px;height:16px}
.nav-name{font-family:var(--fd);font-weight:700;font-size:14px;color:var(--t);letter-spacing:-.01em}
.ntw{display:flex;gap:2px;overflow-x:auto;scrollbar-width:none;max-width:60vw}
.ntw::-webkit-scrollbar{display:none}
.ntab{padding:5px 11px;border-radius:8px;font-family:var(--fm);font-size:10px;letter-spacing:.04em;color:var(--t2);cursor:none;white-space:nowrap;transition:all .2s;border:1px solid transparent}
.ntab:hover,.ntab.on{color:var(--t);background:var(--bg3);border-color:var(--brd)}
.tog{width:40px;height:23px;border-radius:12px;background:var(--tog);border:1px solid var(--brd);position:relative;cursor:none;transition:background .3s;flex-shrink:0}
.tog-k{position:absolute;top:2px;left:2px;width:17px;height:17px;border-radius:50%;background:var(--t);transition:transform .3s var(--spring);display:flex;align-items:center;justify-content:center;font-size:8px}
[data-theme="light"] .tog-k{transform:translateX(17px)}
/* HERO */
#hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden}
#hCanvas{position:absolute;inset:0;z-index:0;width:100%;height:100%}
.hero-in{position:relative;z-index:1;max-width:1140px;margin:0 auto;padding:110px 28px 80px;width:100%;display:grid;grid-template-columns:1fr 360px;gap:60px;align-items:center}
.h-ey{display:inline-flex;align-items:center;gap:8px;font-family:var(--fm);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--acc);padding:5px 14px;border-radius:100px;background:var(--accg);border:1px solid var(--acc);margin-bottom:24px;opacity:0;animation:fadeUp .8s .2s forwards}
.h-ey::before{content:"";width:5px;height:5px;border-radius:50%;background:var(--acc);animation:blink 2s infinite}
.h1{font-family:var(--fd);font-size:clamp(52px,7vw,86px);line-height:.97;letter-spacing:-.035em;color:var(--t);margin-bottom:16px;opacity:0;animation:fadeUp .9s .35s forwards;font-weight:800}
.h1 em{font-style:italic;color:var(--acc);font-weight:600}
.h-role{font-size:16px;font-weight:300;color:var(--t2);margin-bottom:18px;opacity:0;animation:fadeUp .9s .45s forwards}
.h-bio{font-size:15px;font-weight:300;color:var(--t2);line-height:1.82;max-width:490px;margin-bottom:32px;opacity:0;animation:fadeUp .9s .55s forwards}
.h-cta{display:flex;gap:11px;flex-wrap:wrap;opacity:0;animation:fadeUp .9s .65s forwards}
.btn{display:inline-flex;align-items:center;gap:7px;padding:11px 22px;border-radius:100px;font-size:14px;font-weight:500;cursor:none;transition:all .22s;text-decoration:none;font-family:var(--fb)}
.btn-p{background:var(--acc);color:#fff}.btn-p:hover{opacity:.88;transform:scale(.98)}
.btn-g{background:var(--bg3);color:var(--t);border:1px solid var(--brd)}.btn-g:hover{background:var(--bg4);border-color:var(--brdh)}
/* HERO CARD */
.hcard{background:var(--bg2);border:1px solid var(--brd);border-radius:24px;overflow:hidden;box-shadow:var(--sh);opacity:0;animation:fadeUp .9s .8s forwards}
.hc-photo{width:100%;height:240px;overflow:hidden;position:relative}
.hc-photo img{width:100%;height:100%;object-fit:cover;object-position:center 15%;display:block}
.hc-fade{position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(transparent,var(--bg2))}
.hc-body{padding:20px 24px 24px}
.hc-name{font-family:var(--fd);font-weight:800;font-size:18px;color:var(--t);letter-spacing:-.02em}
.hc-sub{font-size:12px;color:var(--t2);font-weight:300;margin-top:3px;margin-bottom:16px}
.hc-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.hc-stat{background:var(--bg3);border-radius:10px;padding:11px;border:1px solid var(--brd)}
.hc-v{font-family:var(--fd);font-weight:700;font-size:19px;line-height:1;color:var(--t)}
.hc-l{font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.06em;margin-top:3px}
.hc-links{display:flex;flex-direction:column;gap:6px}
.hc-lnk{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;background:var(--bg3);border:1px solid var(--brd);text-decoration:none;color:var(--t2);font-size:12px;font-weight:500;transition:all .22s}
.hc-lnk:hover{background:var(--bg4);color:var(--t);border-color:var(--brdh)}
.hc-ic{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0}
.scroll-hint{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;font-family:var(--fm);font-size:10px;letter-spacing:.2em;color:var(--t3);opacity:0;animation:fadeUp 1s 1.6s forwards;z-index:2}
.sline{width:1px;height:36px;background:linear-gradient(to bottom,var(--acc),transparent);animation:spulse 2s infinite}
/* PROJECT SECTIONS */
.pitem{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden}
.pcwrap{position:absolute;inset:0;z-index:0;overflow:hidden;background:#000000}
.pcwrap canvas{width:100%!important;height:100%!important;display:block}
.dg{position:absolute;inset:0;z-index:0;background-image:linear-gradient(rgba(255,255,255,.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.015) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse at center,black 10%,transparent 72%);pointer-events:none}
.pfade{position:absolute;inset:0;z-index:1;pointer-events:none}
.pin{position:relative;z-index:2;max-width:1140px;margin:0 auto;padding:80px 28px;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center}
.pin.flip{direction:rtl}.pin.flip>*{direction:ltr}
.pinfo{display:flex;flex-direction:column}
.pnum{font-family:var(--fm);font-size:11px;color:var(--t3);letter-spacing:.1em;margin-bottom:10px}
.paward{display:inline-flex;align-items:center;gap:5px;padding:4px 11px;border-radius:100px;font-family:var(--fm);font-size:9px;font-weight:500;letter-spacing:.05em;text-transform:uppercase;margin-bottom:14px;width:fit-content}
.ag{background:rgba(255,214,10,.12);color:#ffd60a;border:1px solid rgba(255,214,10,.28)}
.ab{background:var(--accg);color:var(--acc);border:1px solid rgba(41,151,255,.28)}
.agr{background:rgba(48,209,88,.1);color:#30d158;border:1px solid rgba(48,209,88,.25)}
.ar{background:rgba(248,113,113,.1);color:#f87171;border:1px solid rgba(248,113,113,.25)}
.ap{background:rgba(167,139,250,.1);color:#a78bfa;border:1px solid rgba(167,139,250,.25)}
.pey{font-family:var(--fm);font-size:11px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:12px;display:inline-flex;align-items:center;gap:6px}
.ptitle{font-family:var(--fd);font-size:clamp(38px,4.5vw,62px);line-height:.97;letter-spacing:-.035em;font-weight:800;margin-bottom:16px}
.pdesc{font-size:14px;font-weight:300;color:var(--t2);line-height:1.82;margin-bottom:22px;max-width:430px}
.pstats{display:flex;gap:24px;margin-bottom:22px;flex-wrap:wrap}
.ps{display:flex;flex-direction:column;gap:3px}
.psv{font-family:var(--fd);font-weight:800;font-size:28px;line-height:1}
.psl{font-family:var(--fm);font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.07em}
.ptags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:24px}
.tag{font-size:10px;font-weight:500;padding:4px 10px;border-radius:100px;background:var(--pill);border:1px solid var(--pillb);color:var(--t2);font-family:var(--fb)}
.plnk{display:inline-flex;align-items:center;gap:8px;padding:12px 26px;border-radius:100px;font-family:var(--fm);font-size:11px;letter-spacing:.08em;font-weight:700;cursor:none;transition:all .28s;width:fit-content;text-decoration:none}
.plnk:hover{transform:scale(1.05)}.plnk svg{transition:transform .25s}.plnk:hover svg{transform:translateX(5px)}
/* Glass panel */
.pglass{background:var(--glass);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);border:1px solid var(--glassb);border-radius:22px;padding:24px;box-shadow:var(--sh)}
.pcl{font-family:var(--fm);font-size:10px;color:var(--t3);margin-bottom:10px;letter-spacing:.08em}
.pccan{width:100%;border-radius:14px;overflow:hidden;margin-bottom:14px;background:rgba(0,0,0,.5)}
.pccan canvas{width:100%!important;height:100%!important;display:block}
.pcrow{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--t2);padding:6px 0;border-bottom:1px solid var(--brd)}
.pcrow:last-child{border-bottom:none;padding-bottom:0}
.pcv{font-family:var(--fm);font-size:11px;font-weight:500}
/* project bg gradients */
.bg-ng{background:radial-gradient(ellipse at 30% 50%,#041808 0%,var(--bg) 70%)}
.bg-sl{background:radial-gradient(ellipse at 70% 40%,#070f26 0%,var(--bg) 70%)}
.bg-4s{background:radial-gradient(ellipse at 30% 50%,#041808 0%,var(--bg) 70%)}
.bg-fg{background:radial-gradient(ellipse at 65% 35%,#001828 0%,var(--bg) 70%)}
.bg-hf{background:radial-gradient(ellipse at 30% 50%,#1c1800 0%,var(--bg) 70%)}
.bg-hv{background:radial-gradient(ellipse at 65% 40%,#1a0800 0%,var(--bg) 70%)}
.bg-eb{background:radial-gradient(ellipse at 30% 50%,#1a0810 0%,var(--bg) 70%)}
.bg-sw{background:radial-gradient(ellipse at 65% 40%,#0c0818 0%,var(--bg) 70%)}
.bg-c7{background:radial-gradient(ellipse at 30% 50%,#041018 0%,var(--bg) 70%)}
.bg-co{background:radial-gradient(ellipse at 65% 40%,#180808 0%,var(--bg) 70%)}
.sdiv{height:1px;background:linear-gradient(90deg,transparent,var(--brd),transparent)}
/* SECTIONS */
.sec{max-width:1140px;margin:0 auto;padding:80px 28px;border-top:1px solid var(--brd)}
.slbl{font-family:var(--fm);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--acc);margin-bottom:10px}
.sh2{font-family:var(--fd);font-size:clamp(34px,4.5vw,52px);line-height:1.05;letter-spacing:-.025em;color:var(--t);margin-bottom:10px;font-weight:800}
.ssub{font-size:15px;font-weight:300;color:var(--t2);max-width:480px;line-height:1.8;margin-bottom:50px}
.erow{display:grid;grid-template-columns:190px 1fr;gap:32px;padding:28px 0;border-bottom:1px solid var(--brd)}
.erow:last-child{border-bottom:none}
.elogo{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:10px;border:1px solid var(--brd)}
.eco{font-family:var(--fd);font-weight:700;font-size:14px;color:var(--t)}
.epd{font-family:var(--fm);font-size:10px;color:var(--t3);letter-spacing:.04em;margin-top:3px}
.erole{font-family:var(--fd);font-weight:700;font-size:17px;color:var(--t);margin-bottom:7px}
.edesc{font-size:14px;font-weight:300;color:var(--t2);line-height:1.78}
.etags{display:flex;flex-wrap:wrap;gap:5px;margin-top:11px}
.agrid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.acard{background:var(--bg2);border:1px solid var(--brd);border-radius:18px;padding:26px}
.acard-h{font-family:var(--fm);font-weight:500;font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:14px}
.ai{display:flex;align-items:flex-start;gap:11px;padding:8px 0;border-bottom:1px solid var(--brd)}
.ai:last-child{border-bottom:none}
.ai-ic{font-size:14px;flex-shrink:0;margin-top:1px}
.ai-t{font-size:13px;color:var(--t2);line-height:1.5}
.ai-t strong{color:var(--t);font-weight:500}
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.ccard{background:var(--bg2);border:1px solid var(--brd);border-radius:18px;padding:26px;text-decoration:none;color:inherit;transition:all .25s;display:flex;flex-direction:column;gap:6px}
.ccard:hover{border-color:var(--brdh);transform:translateY(-2px);box-shadow:var(--sh)}
.cc-ic{font-size:26px;margin-bottom:4px}
.cc-t{font-family:var(--fd);font-weight:700;font-size:16px;color:var(--t)}
.cc-v{font-size:13px;color:var(--acc);font-weight:300}
/* reveal */
.rv{opacity:0;transform:translateY(22px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.rv.d1{transition-delay:.1s}.rv.d2{transition-delay:.2s}.rv.d3{transition-delay:.3s}
.rv.on{opacity:1;transform:translateY(0)}
.pinfo{opacity:0;transform:translateX(-32px);transition:opacity .9s var(--ease),transform .9s var(--ease)}
.pinfo.on{opacity:1;transform:translateX(0)}
.pglass{opacity:0;transform:translateX(32px);transition:opacity .9s .15s var(--ease),transform .9s .15s var(--ease)}
.pglass.on{opacity:1;transform:translateX(0)}
.flip .pinfo{transform:translateX(32px)}.flip .pglass{transform:translateX(-32px)}
footer{border-top:1px solid var(--brd);padding:28px;text-align:center;font-family:var(--fm);font-size:11px;color:var(--t3);letter-spacing:.08em}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
@keyframes spulse{0%,100%{opacity:.3}50%{opacity:1}}
@media(max-width:860px){.hero-in{grid-template-columns:1fr;padding:100px 20px 60px}.hcard{display:none}.pin{grid-template-columns:1fr;padding:60px 20px}.pin.flip{direction:ltr}.pglass{display:none}.erow{grid-template-columns:1fr;gap:8px}.agrid,.cgrid{grid-template-columns:1fr}.ntw{display:none}}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px}

/* ═══════════════════════════════════════════
   CATEGORY QUICK-JUMP BAR
   Shows below nav, always visible
═══════════════════════════════════════════ */
#catBar {
  position: fixed;
  top: 54px; /* sits right below nav */
  left: 0; right: 0;
  z-index: 299;
  background: var(--bg, #07070a);
  border-bottom: 1px solid rgba(255,255,255,.06);
  backdrop-filter: saturate(180%) blur(12px);
  -webkit-backdrop-filter: saturate(180%) blur(12px);
  transition: background .4s;
}
[data-theme="light"] #catBar {
  background: rgba(244,244,248,.95);
  border-color: rgba(0,0,0,.07);
}
.cat-inner {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 28px;
  display: flex;
  align-items: center;
  gap: 4px;
  height: 38px;
}
.cat-label {
  font-family: var(--fm);
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: rgba(80,80,100,1);
  margin-right: 8px;
  white-space: nowrap;
  flex-shrink: 0;
}
[data-theme="light"] .cat-label { color: rgba(100,100,120,1); }
.cat-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 14px;
  border-radius: 100px;
  font-family: var(--fm);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .06em;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all .2s;
  text-transform: uppercase;
  background: transparent;
  white-space: nowrap;
}
.cat-btn:hover { transform: translateY(-1px); }
.cat-btn.internship {
  color: #60a5fa;
  border-color: rgba(96,165,250,.3);
}
.cat-btn.internship:hover {
  background: rgba(96,165,250,.1);
  border-color: rgba(96,165,250,.6);
}
.cat-btn.hackathon {
  color: #fbbf24;
  border-color: rgba(251,191,36,.3);
}
.cat-btn.hackathon:hover {
  background: rgba(251,191,36,.1);
  border-color: rgba(251,191,36,.6);
}
.cat-btn.personal {
  color: #a78bfa;
  border-color: rgba(167,139,250,.3);
}
.cat-btn.personal:hover {
  background: rgba(167,139,250,.1);
  border-color: rgba(167,139,250,.6);
}
.cat-btn .cat-ic {
  font-size: 11px;
}
/* Dropdown menu */
.cat-dropdown {
  position: absolute;
  top: calc(100% + 4px);
  left: 0;
  background: var(--bg2, #0f0f14);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 14px;
  padding: 8px;
  min-width: 200px;
  box-shadow: 0 16px 48px rgba(0,0,0,.6);
  opacity: 0;
  pointer-events: none;
  transform: translateY(-6px);
  transition: opacity .2s, transform .2s;
  z-index: 400;
}
[data-theme="light"] .cat-dropdown {
  background: #f0f0f5;
  border-color: rgba(0,0,0,.1);
  box-shadow: 0 16px 48px rgba(0,0,0,.15);
}
.cat-wrap {
  position: relative;
}
.cat-wrap:hover .cat-dropdown,
.cat-wrap:focus-within .cat-dropdown {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.cat-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  border-radius: 8px;
  cursor: pointer;
  font-family: var(--fm);
  font-size: 11px;
  color: rgba(140,140,160,1);
  transition: all .15s;
  border: none;
  background: transparent;
  width: 100%;
  text-align: left;
}
.cat-item:hover {
  background: rgba(255,255,255,.06);
  color: #f0f0f5;
}
[data-theme="light"] .cat-item:hover {
  background: rgba(0,0,0,.05);
  color: #0a0a14;
}
.cat-item-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.cat-sep {
  height: 1px;
  background: rgba(255,255,255,.06);
  margin: 4px 0;
}
[data-theme="light"] .cat-sep { background: rgba(0,0,0,.07); }
/* Offset hero and sections to account for double bar */
#hero { padding-top: 38px; }
nav { top: 0; }
.bg-nfx{background:radial-gradient(ellipse at 65% 40%,#1a0000 0%,var(--bg) 70%)}

/* Context-loss fallback: ensure sections stay black if 3D fails */
html[data-theme="dark"] .pitem { background: #000000 !important; }
html[data-theme="dark"] .pcwrap { background: #000000 !important; }
html[data-theme="dark"] #hero { background: #000000 !important; }
html[data-theme="dark"] #hCanvas { background: #000000; }
</style>
</head>
